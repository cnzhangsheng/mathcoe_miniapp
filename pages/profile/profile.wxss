/* pages/profile/profile.wxss - 100%复刻 Me.tsx样式 */

.me-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* Profile Header */
.profile-header {
  padding: 48rpx;
  border-radius: 64rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.profile-header::after {
  content: '';
  position: absolute;
  right: -16rpx;
  top: -16rpx;
  width: 96rpx;
  height: 96rpx;
  background-color: #E8F5E9;
  border-radius: 50%;
  opacity: 0.5;
}

.avatar-wrapper {
  position: relative;
  margin-right: 40rpx;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 56rpx;
  border: 4rpx solid rgba(7, 193, 96, 0.2);
  padding: 8rpx;
}

.edit-btn {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 56rpx;
  height: 56rpx;
  background-color: #1A1A1A;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}

.edit-icon {
  font-size: 14px;
}

.profile-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.profile-name {
  font-size: 20px;
  font-weight: 900;
}

.level-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background-color: #FEF3C7;
  border-radius: 32rpx;
  border: 2rpx solid #FCD34D;
}

.level-icon {
  font-size: 10px;
}

.level-text {
  font-size: 9px;
  font-weight: 900;
  color: #B45309;
}

.grade-picker {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: #f0f0f0;
  border-radius: 24rpx;
}

.grade-text {
  font-size: 11px;
  font-weight: bold;
  color: #666;
}

.picker-arrow {
  font-size: 12px;
  color: #999;
  margin-left: 8rpx;
}

.settings-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #f0f0f0;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-icon {
  font-size: 20px;
}

/* Stats Row */
.stats-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 32rpx;
  border-radius: 56rpx;
}

.stat-value {
  display: block;
  font-size: 20px;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 9px;
  color: #666;
  font-weight: 900;
  letter-spacing: 2rpx;
}

/* Calendar */
.calendar-card {
  padding: 48rpx;
  border-radius: 64rpx;
  margin-bottom: 24rpx;
}

.calendar-header {
  margin-bottom: 40rpx;
}

.calendar-icon {
  font-size: 20px;
  margin-right: 16rpx;
}

.calendar-title {
  font-size: 16px;
}

.calendar-sub {
  font-size: 11px;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
}

.calendar-day {
  aspect-ratio: 1;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: bold;
  background-color: #f5f5f5;
  color: #999;
}

.calendar-day.active {
  background-color: #07C160;
  color: #fff;
}

/* Honor Card */
.honor-card {
  padding: 64rpx;
  border-radius: 80rpx;
  margin-bottom: 24rpx;
}

.honor-header {
  margin-bottom: 64rpx;
}

.honor-icon-box {
  width: 96rpx;
  height: 96rpx;
  background-color: #EDE9FE;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-right: 24rpx;
}

.honor-title {
  font-size: 18px;
  display: block;
}

.honor-sub {
  font-size: 10px;
  letter-spacing: 4rpx;
}

/* Medals Grid */
.medals-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 48rpx;
  margin-bottom: 80rpx;
  text-align: center;
}

.medal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.medal-box {
  width: 128rpx;
  height: 128rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.medal-box.gradient-bg {
  background: linear-gradient(135deg, #6366F1, #7C3AED, #4F46E5);
  box-shadow: 0 16rpx 48rpx rgba(99, 102, 241, 0.3);
  border: 8rpx solid #fff;
}

.medal-box.gray-bg {
  background-color: #f5f5f5;
}

.medal-emoji {
  font-size: 32px;
}

.medal-title {
  font-size: 10px;
  font-weight: 900;
}

.medal-item.unlocked .medal-title {
  color: #333;
}

.medal-item.locked .medal-title {
  color: #999;
}

.level-tag {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: #EF4444;
  border-radius: 50%;
  border: 4rpx solid #fff;
  font-size: 10px;
  font-weight: 900;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Certificates */
.cert-section {
  margin-bottom: 64rpx;
}

.cert-header {
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.cert-item {
  padding: 32rpx;
  background-color: #f5f5f5;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.cert-check {
  color: #07C160;
  font-size: 16px;
  margin-right: 24rpx;
}

.cert-title {
  font-size: 12px;
  font-weight: 900;
}

.cert-badge {
  font-size: 9px;
  font-weight: 900;
  padding: 8rpx 16rpx;
  background-color: #1A1A1A;
  color: #fff;
  border-radius: 32rpx;
}

.view-all-btn {
  padding: 32rpx;
  background-color: #EDE9FE;
  border-radius: 40rpx;
  text-align: center;
  font-size: 11px;
  font-weight: 900;
  color: #4F46E5;
}

/* Menu Card */
.menu-card {
  background-color: #fff;
  border-radius: 64rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.menu-item {
  padding: 40rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
}

.menu-icon-box.gray-bg {
  background-color: #f5f5f5;
}

.menu-icon {
  font-size: 20px;
}

.menu-text {
  font-size: 15px;
  font-weight: bold;
}

.arrow {
  font-size: 24px;
  color: #ccc;
}

/* Logout Button */
.logout-btn {
  padding: 40rpx;
  background-color: #fff;
  border-radius: 56rpx;
  text-align: center;
  font-size: 16px;
  font-weight: 900;
  color: #EF4444;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

/* Settings Modal */
.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F8F8F8;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.settings-header {
  height: 96rpx;
  padding: 0 32rpx;
  background-color: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  color: #666;
}

.settings-title {
  font-size: 17px;
}

.placeholder {
  width: 80rpx;
}

.settings-content {
  padding: 48rpx;
  flex: 1;
  overflow-y: auto;
}

.setting-section {
  margin-bottom: 64rpx;
}

.setting-label {
  font-size: 14px;
}

.setting-value {
  font-size: 20px;
}

.goal-options {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.goal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 12px;
  font-weight: bold;
  background-color: #fff;
  border: 2rpx solid #f0f0f0;
  color: #999;
}

.goal-btn.active {
  background-color: #07C160;
  color: #fff;
  border: none;
}

.toggle-item {
  padding: 40rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.toggle-icon-box {
  width: 88rpx;
  height: 88rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 32rpx;
}

.toggle-icon-box.blue-bg {
  background-color: #DBEAFE;
}

.toggle-icon-box.rose-bg {
  background-color: #FFE4E6;
}

.toggle-title {
  font-size: 14px;
  display: block;
}

.toggle-desc {
  display: block;
  margin-top: 8rpx;
}

.toggle-switch {
  width: 96rpx;
  height: 48rpx;
  border-radius: 48rpx;
  position: relative;
}

.toggle-switch.on {
  background-color: #07C160;
}

.toggle-switch.off {
  background-color: #f0f0f0;
}

.toggle-dot {
  position: absolute;
  top: 8rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: #fff;
  border-radius: 50%;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.toggle-switch.on .toggle-dot {
  right: 8rpx;
}

.toggle-switch.off .toggle-dot {
  left: 8rpx;
}

.save-btn {
  padding: 40rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 48rpx;
  text-align: center;
  font-size: 16px;
  font-weight: 900;
  margin-top: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(7, 193, 96, 0.2);
}

/* Utility classes */
.card {
  background-color: #fff;
  border-radius: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-muted {
  color: #999;
}

.primary-color {
  color: #07C160;
}