/* pages/profile/profile.wxss - 我的页面（设置页面）样式 */

.profile-page {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

/* Loading State */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx;
  background-color: #fff;
  border-radius: 32rpx;
}

.loading-icon-box {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  font-size: 32rpx;
}

.loading-text {
  color: rgba(0, 0, 0, 0.4);
}

/* User Card */
.user-card {
  padding: 32rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.user-header {
  gap: 24rpx;
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
}

.streak-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.streak-icon {
  font-size: 20rpx;
}

.streak-text {
  color: #DC2626;
}

/* Section Card */
.section-card {
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.section-header {
  padding: 24rpx 32rpx;
  background-color: rgba(0, 0, 0, 0.02);
}

.section-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.6);
}

/* Menu Item */
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.03);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  gap: 20rpx;
}

.menu-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-box.green-bg { background-color: #D1FAE5; }
.menu-icon-box.purple-bg { background-color: #E9D5FF; }
.menu-icon-box.gray-bg { background-color: #F3F4F6; }
.menu-icon-box.blue-bg { background-color: #DBEAFE; }
.menu-icon-box.amber-bg { background-color: #FEF3C7; }
.menu-icon-box.orange-bg { background-color: #FFEDD5; }

.menu-icon {
  font-size: 24rpx;
}

.menu-text {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.85);
}

.menu-right {
  gap: 12rpx;
}

.menu-value {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.7);
}

.menu-arrow {
  color: rgba(0, 0, 0, 0.2);
  font-size: 32rpx;
}

/* Logout Button */
.logout-btn {
  padding: 24rpx;
  background-color: #fff;
  border-radius: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.logout-text {
  font-size: 30rpx;
  color: #EF4444;
}

/* Version Info */
.version-info {
  text-align: center;
  padding: 24rpx;
}

.version-text {
  color: rgba(0, 0, 0, 0.3);
}

/* Picker Modal */
.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: relative;
  width: 100%;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx;
  padding-bottom: 48rpx;
}

.picker-header {
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.picker-title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(0, 0, 0, 0.5);
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.picker-option {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background-color: rgba(0, 0, 0, 0.03);
  border: 2rpx solid transparent;
}

.picker-option.active {
  background-color: #D1FAE5;
  border-color: #07C160;
}

.option-text {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.85);
}

.option-desc {
  color: rgba(0, 0, 0, 0.4);
  margin-top: 4rpx;
}

.picker-option.active .option-text {
  color: #07C160;
}

/* Utility Classes */
.card {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-bold {
  font-weight: 700;
}

.text-small {
  font-size: 24rpx;
}

.text-muted {
  color: rgba(0, 0, 0, 0.4);
}

.primary-color {
  color: #07C160;
}