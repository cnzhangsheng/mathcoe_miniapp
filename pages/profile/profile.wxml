<!--pages/profile/profile.wxml - 我的页面（设置页面） -->
<view class="profile-page">

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-card">
      <view class="loading-icon-box">
        <text class="loading-icon">🔄</text>
      </view>
      <text class="loading-text text-small">正在加载...</text>
    </view>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 用户信息 -->
    <view class="user-card card">
      <view class="user-header flex-row">
        <view class="avatar-wrapper">
          <image class="user-avatar" src="{{userInfo.avatar_url || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
        </view>
        <view class="user-info">
          <text class="user-name text-bold">{{userInfo.nickname || '数学小达人'}}</text>
          <view class="streak-row" wx:if="{{streakDays > 0}}">
            <text class="streak-icon">🔥</text>
            <text class="streak-text text-small">连续学习 {{streakDays}} 天</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 学习设置 -->
    <view class="section-card card">
      <view class="section-header">
        <text class="section-title text-bold">学习设置</text>
      </view>

      <view class="menu-item" bindtap="goToRecords">
        <view class="menu-left flex-row">
          <view class="menu-icon-box amber-bg">
            <text class="menu-icon">🏆</text>
          </view>
          <text class="menu-text">答题记录</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="openGoalPicker">
        <view class="menu-left flex-row">
          <view class="menu-icon-box green-bg">
            <text class="menu-icon">🎯</text>
          </view>
          <text class="menu-text">每日目标</text>
        </view>
        <view class="menu-right flex-row">
          <text class="menu-value text-bold primary-color">{{dailyGoal}} 题</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-item" bindtap="openGradePicker">
        <view class="menu-left flex-row">
          <view class="menu-icon-box purple-bg">
            <text class="menu-icon">📚</text>
          </view>
          <text class="menu-text">学习年级</text>
        </view>
        <view class="menu-right flex-row">
          <text class="menu-value text-bold">{{gradeLabels[gradeIndex].label}}</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 系统设置 -->
    <view class="section-card card">
      <view class="section-header">
        <text class="section-title text-bold">系统设置</text>
      </view>

      <view class="menu-item" bindtap="goToAbout">
        <view class="menu-left flex-row">
          <view class="menu-icon-box gray-bg">
            <text class="menu-icon">📖</text>
          </view>
          <text class="menu-text">关于袋鼠数学</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="clearCache">
        <view class="menu-left flex-row">
          <view class="menu-icon-box blue-bg">
            <text class="menu-icon">🗑️</text>
          </view>
          <text class="menu-text">清除缓存</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bindtap="logout">
      <text class="logout-text text-bold">退出登录</text>
    </view>

    <!-- 版本信息 -->
    <view class="version-info">
      <text class="version-text text-small text-muted">版本 1.0.0</text>
    </view>
  </block>

  <!-- 每日目标选择弹窗 -->
  <view wx:if="{{showGoalPicker}}" class="picker-modal">
    <view class="picker-mask" bindtap="closeGoalPicker"></view>
    <view class="picker-content">
      <view class="picker-header flex-between">
        <text class="picker-title text-bold">选择每日目标</text>
        <view class="picker-close" bindtap="closeGoalPicker">
          <text>✕</text>
        </view>
      </view>
      <view class="picker-options">
        <view class="picker-option {{dailyGoal === 5 ? 'active' : ''}}" bindtap="setDailyGoal" data-goal="{{5}}">
          <text class="option-text text-bold">5 题/天</text>
          <text class="option-desc text-small text-muted">轻松入门</text>
        </view>
        <view class="picker-option {{dailyGoal === 10 ? 'active' : ''}}" bindtap="setDailyGoal" data-goal="{{10}}">
          <text class="option-text text-bold">10 题/天</text>
          <text class="option-desc text-small text-muted">推荐</text>
        </view>
        <view class="picker-option {{dailyGoal === 15 ? 'active' : ''}}" bindtap="setDailyGoal" data-goal="{{15}}">
          <text class="option-text text-bold">15 题/天</text>
          <text class="option-desc text-small text-muted">进阶提升</text>
        </view>
        <view class="picker-option {{dailyGoal === 20 ? 'active' : ''}}" bindtap="setDailyGoal" data-goal="{{20}}">
          <text class="option-text text-bold">20 题/天</text>
          <text class="option-desc text-small text-muted">冲刺满分</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 年级选择弹窗 -->
  <view wx:if="{{showGradePicker}}" class="picker-modal">
    <view class="picker-mask" bindtap="closeGradePicker"></view>
    <view class="picker-content">
      <view class="picker-header flex-between">
        <text class="picker-title text-bold">选择学习年级</text>
        <view class="picker-close" bindtap="closeGradePicker">
          <text>✕</text>
        </view>
      </view>
      <view class="picker-options">
        <block wx:for="{{gradeLabels}}" wx:key="value">
          <view class="picker-option {{gradeIndex === index ? 'active' : ''}}" bindtap="selectGrade" data-index="{{index}}">
            <text class="option-text text-bold">{{item.label}}</text>
            <text class="option-desc text-small text-muted">{{item.desc}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>
</view>