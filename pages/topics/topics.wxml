<!--pages/topics/topics.wxml - 100%复刻 kangaroo-math-brain TopicTraining -->
<view class="topics-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- AI Mastery Insight -->
    <view class="insight-card" wx:if="{{insightData}}">
      <view class="insight-decorator"></view>
      <view class="insight-content">
        <view class="insight-header flex-row">
          <view class="insight-icon-box">
            <text>✨</text>
          </view>
          <text class="insight-title text-small text-bold">AI 学习洞察</text>
        </view>
        <view class="insight-message">
          <text class="text-bold">你在 <text class="highlight">{{insightData.weakest_topic_title}}</text> 模块表现略显吃力，建议本周重点突破。</text>
        </view>
        <view class="insight-footer flex-row">
          <view class="insight-badge">
            <text class="badge-icon">📈</text>
            <text class="badge-text text-small text-bold">进度提升 {{insightData.progress_gain}}%</text>
          </view>
          <text class="insight-sub text-small">基于最近 {{insightData.analysis_base}} 道练习分析</text>
        </view>
      </view>
    </view>

    <!-- Topics Grid (1 row, 3 columns) -->
    <view class="topics-section">
      <view class="section-header flex-row">
        <text class="section-title text-bold">重点突破专题</text>
      </view>

      <view class="topics-grid">
        <block wx:for="{{filteredTopics}}" wx:key="id">
          <view class="topic-card" data-id="{{item.id}}" bindtap="selectTopic">
            <view class="topic-icon-box {{item.bgClass}}">
              <text class="topic-icon">{{item.iconEmoji}}</text>
            </view>
            <view class="topic-info">
              <text class="topic-title text-small text-bold">{{item.title}}</text>
              <view class="topic-progress-bar">
                <view class="topic-progress-fill {{item.progressClass}}" style="width: {{item.progress}}%;"></view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- Exam Papers Section -->
    <view class="exam-section">
      <view class="section-header flex-row">
        <text class="section-title text-bold">模拟考场 ({{totalExamPapers}}张)</text>
        <text class="section-more text-small text-bold">More Exams</text>
      </view>

      <view class="exam-list">
        <block wx:for="{{examPapers}}" wx:key="id">
          <view class="exam-card" data-id="{{item.id}}" bindtap="selectExamPaper">
            <view class="exam-left">
              <view class="exam-icon-box">
                <text class="exam-icon">📝</text>
              </view>
            </view>
            <view class="exam-middle">
              <view class="exam-top flex-row">
                <view class="level-badge">
                  <text class="level-text text-bold">Level {{item.difficulty_level}}</text>
                </view>
                <view class="new-badge" wx:if="{{item.isNew}}">
                  <text class="new-text text-bold">New</text>
                </view>
                <text class="exam-year">{{item.year}} 真题集</text>
              </view>
              <text class="exam-title text-bold">{{item.title}}</text>
              <view class="exam-bottom flex-row">
                <view class="exam-meta flex-row">
                  <text class="meta-icon">⏱</text>
                  <text class="meta-text">{{item.duration || 75}} 分钟</text>
                </view>
                <text class="meta-text">{{item.total_questions}} 题</text>
              </view>
            </view>
            <view class="exam-right">
              <view class="arrow-box">
                <text class="arrow-icon">›</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <!-- 加载更多提示 -->
      <view class="load-more" wx:if="{{examPapersLoading}}">
        <text class="load-more-text text-small text-muted">加载中...</text>
      </view>

      <!-- 底部提示 -->
      <view class="end-tip" wx:if="{{!hasMoreExamPapers && examPapers.length > 0}}">
        <text class="end-tip-text text-small text-muted">——已经到底啦——</text>
      </view>

      <!-- 无数据提示 -->
      <view class="no-data" wx:if="{{examPapers.length === 0 && !examPapersLoading}}">
        <text class="no-data-text text-small">暂无考卷数据</text>
      </view>
    </view>
  </block>
</view>