/* pages/topics/topics.wxss - 100%复刻 TopicTraining.tsx样式 */

.topics-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* AI Mastery Insight */
.insight-card {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.9) 0%, rgba(168, 85, 247, 0.9) 100%);
  border-radius: 64rpx;
  padding: 48rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 24rpx 48rpx rgba(99, 102, 241, 0.3);
  margin-bottom: 24rpx;
}

.insight-decorator {
  position: absolute;
  right: -10%;
  top: -10%;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 50%;
  filter: blur(32rpx);
}

.insight-content {
  position: relative;
  z-index: 1;
}

.insight-header {
  margin-bottom: 32rpx;
}

.insight-icon-box {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255,255,255,0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  margin-right: 16rpx;
}

.insight-title {
  letter-spacing: 4rpx;
  opacity: 0.8;
}

.insight-message {
  margin-bottom: 24rpx;
}

.highlight {
  color: rgba(251, 191, 36, 1);
}

.insight-footer {
  gap: 32rpx;
  padding-top: 16rpx;
}

.insight-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 48rpx;
}

.badge-icon {
  font-size: 12px;
  color: rgba(16, 185, 129, 1);
}

.insight-sub {
  opacity: 0.5;
}

/* Filter Tabs */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  background-color: rgba(0,0,0,0.03);
  padding: 12rpx;
  border-radius: 44rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  margin-bottom: 24rpx;
}

.filter-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 32rpx;
  color: rgba(0,0,0,0.3);
}

.filter-tab.active {
  background-color: #fff;
  color: #1A1A1A;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.filter-icon {
  font-size: 12px;
}

/* Topics List */
.topics-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.topic-card {
  padding: 40rpx;
  border-radius: 56rpx;
  position: relative;
  overflow: hidden;
}

.ai-badge {
  position: absolute;
  top: 0;
  left: 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(90deg, rgba(168, 85, 247, 0.9) 0%, rgba(99, 102, 241, 0.9) 100%);
  color: #fff;
  border-radius: 0 0 32rpx 0;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1);
}

.ai-badge-icon {
  font-size: 10px;
}

.topic-main {
  padding-top: 16rpx;
}

.topic-icon-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
}

.topic-icon {
  font-size: 32px;
}

.bg-blue {
  background-color: rgba(59, 130, 246, 0.1);
  color: rgba(59, 130, 246, 1);
}

.bg-purple {
  background-color: rgba(168, 85, 247, 0.1);
  color: rgba(168, 85, 247, 1);
}

.bg-emerald {
  background-color: rgba(16, 185, 129, 0.1);
  color: rgba(16, 185, 129, 1);
}

.bg-amber {
  background-color: rgba(251, 191, 36, 0.1);
  color: rgba(251, 191, 36, 1);
}

.bg-rose {
  background-color: rgba(244, 63, 94, 0.1);
  color: rgba(244, 63, 94, 1);
}

.topic-info {
  flex: 1;
  min-width: 0;
}

.topic-header {
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.topic-title {
  font-size: 16px;
  display: block;
}

.topic-tags {
  gap: 16rpx;
  margin-top: 8rpx;
}

.diff-tag {
  padding: 8rpx 12rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 8rpx;
  color: rgba(0,0,0,0.4);
  letter-spacing: -1rpx;
}

.freq-tag {
  padding: 8rpx 12rpx;
  background-color: rgba(239, 68, 68, 0.1);
  border-radius: 8rpx;
  color: rgba(239, 68, 68, 1);
  letter-spacing: -1rpx;
}

.topic-progress-box {
  text-align: right;
}

.progress-value {
  font-size: 12px;
  display: block;
}

.progress-label {
  letter-spacing: -1rpx;
  display: block;
  line-height: 1;
}

.topic-desc {
  display: block;
  color: rgba(0,0,0,0.4);
  line-height: 1.5;
  margin-top: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.topic-footer {
  margin-top: 24rpx;
  gap: 32rpx;
}

.topic-progress-bar {
  flex: 1;
  height: 12rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 12rpx;
}

.progress-blue {
  background-color: rgba(59, 130, 246, 0.7);
}

.progress-purple {
  background-color: rgba(168, 85, 247, 0.7);
}

.progress-emerald {
  background-color: #07C160;
}

.progress-amber {
  background-color: rgba(251, 191, 36, 0.7);
}

.progress-rose {
  background-color: rgba(244, 63, 94, 0.7);
}

.success-rate-box {
  gap: 8rpx;
}

.rate-high {
  color: rgba(16, 185, 129, 1);
}

.rate-medium {
  color: rgba(251, 191, 36, 1);
}

.rate-low {
  color: rgba(244, 63, 94, 1);
}

/* Continue Button */
.continue-btn {
  background-color: #1A1A1A;
  color: #fff;
  padding: 40rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
  margin-top: 32rpx;
}

.continue-icon {
  font-size: 16px;
}

.continue-label {
  font-size: 14px;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F8F8F8;
  z-index: 100;
}

.topic-detail-modal {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.modal-header-bar {
  height: 128rpx;
  background-color: #fff;
  border-bottom: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
  font-size: 24px;
  color: rgba(0,0,0,0.6);
}

.modal-header-title {
  font-size: 17px;
  flex: 1;
  text-align: center;
  margin-right: 80rpx;
}

.detail-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 48rpx;
}

/* Detail Header Card */
.detail-header-card {
  padding: 64rpx;
  border-radius: 80rpx;
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.detail-decorator {
  position: absolute;
  top: 0;
  right: 0;
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  opacity: 0.1;
  filter: blur(32rpx);
  margin-top: -128rpx;
  margin-right: -128rpx;
}

.detail-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.detail-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
}

.detail-icon {
  font-size: 40px;
}

.detail-title {
  font-size: 20px;
  display: block;
  margin-bottom: 16rpx;
}

.detail-desc {
  max-width: 480rpx;
  line-height: 1.6;
}

.detail-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
  margin-top: 64rpx;
  padding-top: 64rpx;
  border-top: 2rpx solid rgba(0,0,0,0.03);
}

.stat-box {
  text-align: center;
}

.stat-label {
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 20px;
}

/* Learning Section */
.learning-section {
  margin-top: 32rpx;
}

.section-title {
  letter-spacing: 4rpx;
  color: rgba(0,0,0,0.3);
  margin-left: 32rpx;
  margin-bottom: 32rpx;
}

.learning-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.learning-card {
  padding: 48rpx;
  border-radius: 64rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.learning-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.indigo-icon {
  background-color: rgba(99, 102, 241, 0.1);
  color: rgba(99, 102, 241, 1);
}

.amber-icon {
  background-color: rgba(251, 191, 36, 0.1);
  color: rgba(251, 191, 36, 1);
}

.emerald-icon {
  background-color: rgba(16, 185, 129, 0.1);
  color: rgba(16, 185, 129, 1);
}

.learning-title {
  display: block;
}

.learning-sub {
  letter-spacing: -1rpx;
}

.achievement-card {
  padding: 48rpx;
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
}

.achievement-left {
  gap: 32rpx;
}

.achievement-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.achievement-text {
  display: flex;
  flex-direction: column;
}

.achievement-title {
  display: block;
}

.achievement-sub {
  margin-top: 8rpx;
}

.achievement-arrow {
  font-size: 20px;
  color: rgba(0,0,0,0.2);
}

/* Knowledge Card */
.knowledge-card {
  background-color: rgba(0,0,0,0.9);
  color: #fff;
  padding: 64rpx;
  border-radius: 80rpx;
  margin-top: 32rpx;
}

.knowledge-title {
  letter-spacing: 4rpx;
  opacity: 0.4;
  margin-bottom: 48rpx;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.knowledge-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.knowledge-label-row {
  justify-content: space-between;
}

.knowledge-label {
  opacity: 0.8;
}

.knowledge-value {
  opacity: 0.4;
}

.knowledge-bar {
  height: 8rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 8rpx;
  overflow: hidden;
}

.knowledge-fill {
  height: 100%;
  border-radius: 8rpx;
}

.bar-emerald {
  background-color: rgba(16, 185, 129, 1);
}

.bar-amber {
  background-color: rgba(251, 191, 36, 1);
}

.bar-indigo {
  background-color: rgba(99, 102, 241, 1);
}

/* Modal Footer */
.modal-footer {
  padding: 48rpx;
  background-color: #fff;
  border-top: 2rpx solid rgba(0,0,0,0.05);
}

.practice-btn {
  background-color: #1A1A1A;
  color: #fff;
  padding: 40rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
}

.practice-icon {
  font-size: 16px;
}

.practice-label {
  font-size: 14px;
}

/* Utility classes */
.card {
  background-color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.card.dark {
  background-color: #1A1A1A;
}

.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-xs {
  font-size: 9px;
}

.text-muted {
  color: rgba(0,0,0,0.3);
}