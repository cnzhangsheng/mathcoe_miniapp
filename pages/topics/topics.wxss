/* pages/topics/topics.wxss - 100%复刻 kangaroo-math-brain */

.topics-container {
  padding: 32rpx;
  padding-bottom: 192rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: rgba(0,0,0,0.4);
}

/* ============ AI Mastery Insight ============ */
.insight-card {
  background: linear-gradient(135deg, #4F46E5 0%, #9333EA 100%);
  border-radius: 64rpx;
  padding: 48rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.insight-decorator {
  position: absolute;
  right: -10%;
  top: -10%;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 50%;
  filter: blur(48rpx);
}

.insight-content {
  position: relative;
  z-index: 1;
}

.insight-header {
  margin-bottom: 16rpx;
}

.insight-icon-box {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255,255,255,0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.insight-title {
  color: rgba(255,255,255,0.8);
  letter-spacing: 2rpx;
}

.insight-message {
  margin-bottom: 16rpx;
  font-size: 15px;
  line-height: 1.5;
}

.highlight {
  color: #FBBF24;
}

.insight-footer {
  gap: 32rpx;
}

.insight-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 32rpx;
}

.insight-sub {
  color: rgba(255,255,255,0.5);
}

/* ============ Section Header ============ */
.section-header {
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

.section-title {
  font-size: 15px;
  color: rgba(0,0,0,0.8);
}

.section-more {
  color: #07C160;
  letter-spacing: 1rpx;
}

/* Tab Group */
.tab-group {
  display: flex;
  gap: 12rpx;
  background-color: rgba(0,0,0,0.05);
  padding: 8rpx;
  border-radius: 24rpx;
}

.tab-item {
  padding: 8rpx 24rpx;
  border-radius: 16rpx;
}

.tab-item.active {
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.tab-text {
  color: rgba(0,0,0,0.4);
}

.tab-item.active .tab-text {
  color: rgba(0,0,0,1);
}

/* ============ Topics Grid (3 columns) ============ */
.topics-section {
  margin-bottom: 32rpx;
}

.topics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.topic-card {
  background-color: #fff;
  padding: 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 24rpx;
}

.topic-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.topic-icon {
  font-size: 24px;
}

/* 颜色映射 */
.bg-blue {
  background-color: rgba(59,130,246,0.1);
  color: #3B82F6;
}

.bg-purple {
  background-color: rgba(168,85,247,0.1);
  color: #A855F7;
}

.bg-emerald {
  background-color: rgba(16,185,129,0.1);
  color: #10B881;
}

.bg-amber {
  background-color: rgba(251,191,36,0.1);
  color: #FBBF24;
}

.bg-rose {
  background-color: rgba(244,63,94,0.1);
  color: #F43F5E;
}

.topic-info {
  width: 100%;
}

.topic-title {
  display: block;
  margin-bottom: 8rpx;
  color: rgba(0,0,0,0.9);
}

.topic-progress-bar {
  width: 100%;
  height: 6rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 6rpx;
  overflow: hidden;
}

.topic-progress-fill {
  height: 100%;
  border-radius: 6rpx;
}

.progress-blue {
  background-color: #3B82F6;
}

.progress-purple {
  background-color: #A855F7;
}

.progress-emerald {
  background-color: #07C160;
}

.progress-amber {
  background-color: #FBBF24;
}

.progress-rose {
  background-color: #F43F5E;
}

/* ============ Exam Papers Section ============ */
.exam-section {
  margin-bottom: 32rpx;
}

.exam-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.exam-card {
  background-color: #fff;
  padding: 40rpx;
  border-radius: 56rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.exam-left {
  margin-right: 32rpx;
}

.exam-icon-box {
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(99,102,241,0.1);
  color: #6366F1;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.exam-icon {
  font-size: 24px;
}

.exam-middle {
  flex: 1;
  min-width: 0;
}

.exam-top {
  margin-bottom: 8rpx;
  gap: 16rpx;
  align-items: center;
}

.level-badge {
  padding: 8rpx 12rpx;
  background-color: #6366F1;
  border-radius: 8rpx;
}

.level-text {
  color: #fff;
  font-size: 10px;
}

.new-badge {
  padding: 8rpx 12rpx;
  background-color: #F43F5E;
  border-radius: 8rpx;
}

.new-text {
  color: #fff;
  font-size: 9px;
}

.exam-year {
  color: rgba(0,0,0,0.4);
  font-size: 10px;
}

.exam-title {
  display: block;
  color: rgba(0,0,0,0.8);
  font-size: 14px;
  margin-bottom: 16rpx;
}

.exam-bottom {
  gap: 32rpx;
  color: rgba(0,0,0,0.3);
  align-items: center;
}

.exam-meta {
  gap: 8rpx;
  align-items: center;
}

.meta-icon {
  font-size: 12px;
}

.meta-text {
  font-size: 10px;
}

.exam-right {
  margin-left: 16rpx;
}

.arrow-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.02);
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 20px;
  color: rgba(0,0,0,0.2);
}

/* Load More */
.load-more {
  padding: 24rpx;
  text-align: center;
}

.load-more-btn {
  padding: 16rpx 32rpx;
  background-color: rgba(0,0,0,0.03);
  border-radius: 24rpx;
}

.load-more-text {
  color: rgba(0, 0, 0, 0.4);
}

/* End Tip */
.end-tip {
  padding: 32rpx 0;
  text-align: center;
}

.end-tip-text {
  color: rgba(0, 0, 0, 0.3);
}

.no-data {
  padding: 48rpx;
  text-align: center;
}

/* ============ Modal Overlay ============ */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F8F8F8;
  z-index: 100;
}

.topic-detail-modal,
.exam-paper-detail-modal {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.modal-header-bar {
  height: 128rpx;
  background-color: #fff;
  border-bottom: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: rgba(0,0,0,0.6);
}

.modal-header-title {
  font-size: 17px;
  flex: 1;
  text-align: center;
  margin-right: 80rpx;
}

.detail-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx 48rpx;
}

/* ============ Detail Header Card ============ */
.detail-header-card {
  background-color: #fff;
  padding: 64rpx;
  border-radius: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.detail-decorator {
  position: absolute;
  top: 0;
  right: 0;
  width: 256rpx;
  height: 256rpx;
  opacity: 0.1;
  filter: blur(48rpx);
  border-radius: 50%;
}

.detail-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.detail-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
}

.detail-icon {
  font-size: 32px;
}

.detail-title {
  font-size: 20px;
  color: rgba(0,0,0,1);
  margin-bottom: 16rpx;
}

.detail-desc {
  color: rgba(0,0,0,0.4);
  max-width: 480rpx;
  line-height: 1.5;
}

.detail-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
  margin-top: 48rpx;
  padding-top: 48rpx;
  border-top: 2rpx solid rgba(0,0,0,0.03);
}

.stat-box {
  text-align: center;
}

.stat-label {
  color: rgba(0,0,0,0.2);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 20px;
  color: rgba(0,0,0,0.9);
}

.rate-high {
  color: #07C160;
}

.rate-low {
  color: #F43F5E;
}

/* ============ Learning Section ============ */
.learning-section {
  margin-bottom: 32rpx;
}

.learning-title {
  color: rgba(0,0,0,0.3);
  letter-spacing: 4rpx;
  margin-bottom: 24rpx;
  margin-left: 32rpx;
}

.learning-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.learning-card {
  background-color: #fff;
  padding: 48rpx;
  border-radius: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.learning-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.learning-icon-box.blue {
  background-color: rgba(99,102,241,0.1);
  color: #6366F1;
}

.learning-icon-box.amber {
  background-color: rgba(251,191,36,0.1);
  color: #FBBF24;
}

.learning-icon {
  font-size: 20px;
}

.learning-title-main {
  color: rgba(0,0,0,1);
}

.learning-sub {
  color: rgba(0,0,0,0.3);
}

/* Achievement Card */
.achievement-card {
  background-color: #fff;
  padding: 48rpx;
  border-radius: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.achievement-left {
  gap: 32rpx;
}

.achievement-icon-box {
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(16,185,129,0.1);
  color: #10B881;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.achievement-icon {
  font-size: 24px;
}

.achievement-title {
  color: rgba(0,0,0,1);
}

.achievement-sub {
  color: rgba(0,0,0,0.3);
}

.achievement-arrow {
  font-size: 20px;
  color: rgba(0,0,0,0.2);
}

/* ============ Knowledge Card ============ */
.knowledge-card {
  background-color: rgba(0,0,0,0.9);
  border-radius: 80rpx;
  padding: 64rpx;
  color: #fff;
}

.knowledge-title {
  color: rgba(255,255,255,0.4);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}

.knowledge-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.knowledge-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.knowledge-top {
  justify-content: space-between;
}

.knowledge-label {
  color: rgba(255,255,255,0.8);
}

.knowledge-val {
  color: rgba(255,255,255,0.4);
}

.knowledge-bar {
  width: 100%;
  height: 8rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 8rpx;
  overflow: hidden;
}

.knowledge-fill {
  height: 100%;
  border-radius: 8rpx;
}

.knowledge-emerald {
  background-color: #10B881;
}

.knowledge-amber {
  background-color: #FBBF24;
}

.knowledge-indigo {
  background-color: #6366F1;
}

/* ============ Exam Paper Detail ============ */
.exam-paper-header {
  background-color: #fff;
  padding: 48rpx;
  border-radius: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  margin-bottom: 32rpx;
}

.paper-header-top {
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.paper-icon-box {
  width: 112rpx;
  height: 112rpx;
  background-color: rgba(255,255,255,0.9);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paper-icon {
  font-size: 28px;
}

.paper-level-badge {
  padding: 12rpx 24rpx;
  background-color: rgba(99,102,241,0.1);
  border-radius: 16rpx;
}

.paper-level-text {
  color: #6366F1;
}

.paper-title {
  font-size: 16px;
  color: rgba(0,0,0,1);
  margin-bottom: 8rpx;
}

.paper-type {
  color: rgba(0,0,0,0.4);
  margin-bottom: 16rpx;
}

.paper-desc {
  color: rgba(0,0,0,0.5);
  line-height: 1.5;
}

.paper-stats {
  display: flex;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(0,0,0,0.05);
}

.paper-stat {
  gap: 8rpx;
}

.stat-icon {
  font-size: 14px;
}

.stat-val {
  font-size: 15px;
}

/* Questions Preview */
.questions-preview {
  margin-top: 32rpx;
}

.preview-title {
  color: rgba(0,0,0,0.4);
  margin-bottom: 24rpx;
}

.preview-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-item {
  background-color: #fff;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.preview-num {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(99,102,241,0.1);
  border-radius: 16rpx;
  justify-content: center;
}

.preview-num-text {
  color: #6366F1;
}

.preview-title-text {
  flex: 1;
  color: rgba(0,0,0,0.8);
}

/* ============ Modal Footer ============ */
.modal-footer {
  padding: 32rpx 48rpx;
  background-color: #fff;
  border-top: 2rpx solid rgba(0,0,0,0.05);
}

.practice-btn {
  background-color: #1A1A1A;
  color: #fff;
  padding: 40rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
}

.practice-icon {
  font-size: 14px;
}

.practice-label {
  font-size: 15px;
}

/* ============ Utility classes ============ */
.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: bold;
}

.text-small {
  font-size: 12px;
}

.text-xs {
  font-size: 10px;
}

.text-muted {
  color: rgba(0,0,0,0.4);
}