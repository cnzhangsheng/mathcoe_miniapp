/* pages/topic-review/topic-review.wxss */

.topic-review-page {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.header-left {
  gap: 16rpx;
}

.topic-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.topic-icon-box.blue-bg { background-color: #DBEAFE; }
.topic-icon-box.purple-bg { background-color: #E9D5FF; }
.topic-icon-box.green-bg { background-color: #D1FAE5; }
.topic-icon-box.amber-bg { background-color: #FEF3C7; }
.topic-icon-box.rose-bg { background-color: #FFE4E6; }
.topic-icon-box.gray-bg { background-color: #F3F4F6; }

.topic-icon {
  font-size: 28rpx;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.85);
}

.start-btn {
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
}

.start-text {
  color: #fff;
}

.section-card {
  border-radius: 24rpx;
}

.section-header {
  padding: 24rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.03);
}

.section-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
}

.question-list {
  padding: 16rpx;
}

.question-item {
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 20rpx;
}

.question-top {
  margin-bottom: 12rpx;
}

.retry-text {
  color: rgba(0, 0, 0, 0.4);
}

.question-content {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.question-bottom {
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.03);
}

.date-text {
  color: rgba(0, 0, 0, 0.4);
}

.action-btns {
  gap: 12rpx;
}

.mini-btn {
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
}

.mini-btn.primary-bg {
  background-color: #07C160;
}

.mini-btn.outline-btn {
  background-color: rgba(0, 0, 0, 0.05);
}

.mini-btn.primary-bg .mini-text {
  color: #fff;
}

.mini-btn.outline-btn .mini-text {
  color: rgba(0, 0, 0, 0.6);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.3);
}

.card {
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-bold {
  font-weight: bold;
}

.text-small {
  font-size: 24rpx;
}

.text-muted {
  color: rgba(0, 0, 0, 0.4);
}

.primary-bg {
  background-color: #07C160;
}