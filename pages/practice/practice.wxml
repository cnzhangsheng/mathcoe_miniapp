<!--pages/practice/practice.wxml - 100%复刻 kangaroo-math-brain Practice.tsx -->
<view class="practice-page">

  <!-- Exam Status Bar (Timer) -->
  <view class="exam-status-bar" wx:if="{{examPaperMode}}">
    <!-- 考卷标题 -->
    <view class="status-center">
      <text class="exam-title text-bold">{{examPaper.title || '考卷测试'}}</text>
    </view>
    <!-- 计时器 -->
    <view class="timer-box {{timeLeft >= 300 ? '' : 'urgent'}}">
      <text class="timer-text text-bold">{{formattedTime || '0:00'}}</text>
    </view>
  </view>

  <!-- Main Practice Card -->
  <view class="practice-card">
    <!-- Question Header -->
    <view class="question-header flex-row">
      <text class="question-number text-bold">题目{{currentIndex}}</text>
      <text class="question-type-text">（{{questionTypeText}}）</text>
    </view>

    <!-- Question Content -->
    <view class="question-content-box">
      <rich-text class="question-content" nodes="{{currentQuestion.contentHtml || '题目内容'}}"></rich-text>
    </view>

    <!-- Question Image Area -->
    <view class="image-area" wx:if="{{currentQuestion.content && currentQuestion.content.images}}">
      <block wx:for="{{currentQuestion.content.images}}" wx:key="*this">
        <image class="question-image" src="{{item}}" mode="aspectFit"></image>
      </block>
    </view>

    <!-- Options Grid (One per row) -->
    <view class="options-grid">
      <block wx:for="{{options}}" wx:key="label">
        <view class="option-item {{selectedOption === item.label ? 'selected' : ''}} {{results[currentIndex] === item.label ? 'answered' : ''}} {{showFeedback && correctAnswer === item.label ? 'correct' : ''}}"
          data-option="{{item.label}}"
          bindtap="selectOption">
          <view class="option-label-box {{selectedOption === item.label || results[currentIndex] === item.label ? 'active-label' : ''}} {{showFeedback && correctAnswer === item.label ? 'correct-label' : ''}}">
            <text class="option-label text-bold">{{item.label}}</text>
          </view>
          <rich-text class="option-text {{selectedOption === item.label || results[currentIndex] === item.label ? 'active-text' : ''}}" nodes="{{item.textHtml}}"></rich-text>
        </view>
      </block>
    </view>
  </view>

  <!-- Bottom Control Bar -->
  <view class="bottom-control-bar">
    <view class="sheet-btn-bottom" bindtap="showAnswerSheet">
      <text class="sheet-icon">📋</text>
      <text class="sheet-text">答题卡</text>
    </view>
    <view class="nav-btn {{currentIndex <= 1 ? 'disabled' : ''}}" bindtap="goToPrevQuestion">
      <text class="nav-icon">‹</text>
      <text class="nav-text">上一题</text>
    </view>
    <view class="nav-btn {{currentIndex >= totalQuestions ? 'submit-btn' : ''}}" bindtap="handleNextOrSubmit">
      <text class="nav-text">{{currentIndex >= totalQuestions ? '确认交卷' : '下一题'}}</text>
      <text class="nav-icon" wx:if="{{currentIndex < totalQuestions}}">›</text>
    </view>
  </view>

  <!-- Answer Feedback (Practice Mode Only) -->
  <view class="feedback-section" wx:if="{{!examPaperMode && showFeedback}}">
    <view class="feedback-card">
      <view class="feedback-decorator"></view>
      <view class="feedback-header flex-row">
        <view class="feedback-icon-box success">
          <text class="feedback-icon">✓</text>
        </view>
        <view class="feedback-text-area">
          <text class="feedback-title text-bold">回答正确！</text>
          <text class="feedback-sub text-xs">Excellent Work</text>
        </view>
      </view>

      <!-- Explanation -->
      <view class="explanation-box flex-row">
        <view class="explanation-marker"></view>
        <view class="explanation-content">
          <text class="explanation-label text-bold">解题思路：</text>
          <text class="explanation-text">{{explanation}}</text>
        </view>
      </view>

      <!-- Tip Card -->
      <view class="tip-card flex-row">
        <view class="tip-icon-box">
          <text class="tip-icon">💡</text>
        </view>
        <view class="tip-info">
          <text class="tip-title text-small text-bold">竞赛考点：一共有 11 种合法展开图</text>
          <text class="tip-sub text-xs">Level 2 Space Geometry</text>
        </view>
      </view>
    </view>

    <view class="end-btn" bindtap="finishPractice">
      <text class="end-text text-bold">结束并返回</text>
      <text class="end-arrow">›</text>
    </view>
  </view>

  <!-- Unanswered Warning Modal -->
  <view class="warning-modal" wx:if="{{showUnansweredWarning}}">
    <view class="warning-mask"></view>
    <view class="warning-card">
      <view class="warning-icon-box">
        <text class="warning-icon">⚠️</text>
      </view>
      <text class="warning-title text-bold">题目还未完成，确认继续交卷？</text>
      <text class="warning-sub">未作答的题目将被判定为回答错误</text>
      <view class="warning-buttons">
        <view class="warning-btn cancel" bindtap="returnToAnswer">
          <text class="warning-btn-text text-bold">返回作答</text>
        </view>
        <view class="warning-btn confirm" bindtap="confirmSubmit">
          <text class="warning-btn-text text-bold">确认交卷</text>
        </view>
      </view>
    </view>
  </view>

  </view>