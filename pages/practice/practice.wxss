/* pages/practice/practice.wxss - 100%复刻 kangaroo-math-brain Practice.tsx */

.practice-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 256rpx;
  background-color: #F8F8F8;
  position: relative;
}

/* ============ Exam Status Bar ============ */
.exam-status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
  background-color: #fff;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: rgba(0,0,0,0.6);
}

.status-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.question-badge {
  font-size: 28rpx;
  color: rgba(0,0,0,0.8);
}

.question-type-tag {
  font-size: 22rpx;
  color: rgba(0,0,0,0.5);
  padding: 8rpx 20rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 24rpx;
}

.progress-label {
  font-size: 28rpx;
  color: rgba(0,0,0,0.6);
}

.timer-box {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background-color: rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
}

.timer-box.urgent {
  background-color: rgba(239,68,68,0.1);
}

.timer-text {
  font-size: 28rpx;
  color: rgba(0,0,0,0.7);
}

.timer-box.urgent .timer-text {
  color: #EF4444;
}

/* ============ Progress Bar (Exam Mode) ============ */
.progress-section {
  padding: 16rpx;
  margin-bottom: 32rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #07C160;
  border-radius: 12rpx;
}

/* ============ Main Practice Card ============ */
.practice-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  margin: 16rpx;
}

.question-title-box {
  margin-bottom: 48rpx;
}

/* rich-text 样式 */
.question-content-box {
  margin-bottom: 48rpx;
}

.question-content {
  font-size: 36rpx;
  color: rgba(0,0,0,0.9);
  line-height: 1.6;
}

.question-content p {
  margin: 0;
  line-height: 1.6;
}

.option-text {
  font-size: 30rpx;
  color: rgba(0,0,0,0.3);
  line-height: 1.5;
}

.option-text p {
  margin: 0;
}

.active-text {
  color: rgba(0,0,0,0.8);
}

/* Question Image Area */
.image-area {
  background-color: rgba(0,0,0,0.02);
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.question-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 32rpx;
}

/* ============ Options Grid ============ */
.options-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  padding: 32rpx 48rpx;
  border-radius: 48rpx;
  border: 6rpx solid rgba(0,0,0,0.03);
  background-color: #fff;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.option-item.selected {
  background-color: rgba(16,185,129,0.1);
  border-color: #07C160;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.option-item.answered {
  background-color: rgba(16,185,129,0.08);
  border-color: rgba(16,185,129,0.3);
}

.option-item.correct {
  background-color: rgba(16,185,129,0.15);
  border-color: #07C160;
}

.option-label-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  background-color: rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-label-box.active-label {
  background-color: #07C160;
}

.option-label-box.correct-label {
  background-color: #07C160;
}

.option-label {
  font-size: 15px;
  color: rgba(0,0,0,0.3);
}

.option-label-box.active-label .option-label,
.option-label-box.correct-label .option-label {
  color: #fff;
}

/* ============ Control Buttons ============ */
.control-section {
  margin-top: 48rpx;
  padding: 16rpx 32rpx;
}

.control-row {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
}

.sheet-btn {
  width: 14%;
  padding: 22rpx 12rpx;
  background-color: #fff;
  border: 2rpx solid rgba(0,0,0,0.05);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.sheet-icon {
  font-size: 26rpx;
}

.sheet-text {
  font-size: 20rpx;
  color: rgba(0,0,0,0.6);
}

.nav-buttons {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.prev-btn, .next-btn {
  flex: 1;
  padding: 22rpx 32rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.prev-btn.active, .next-btn.active {
  background-color: #07C160;
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(7,193,96,0.12);
}

.prev-btn.disabled {
  background-color: rgba(0,0,0,0.04);
  color: rgba(0,0,0,0.25);
}

.next-btn.disabled {
  background-color: rgba(0,0,0,0.04);
  color: rgba(0,0,0,0.25);
}

.nav-text {
  font-size: 28rpx;
}

/* ============ Feedback Section (Practice Mode) ============ */
.feedback-section {
  margin-top: 48rpx;
  padding: 16rpx;
}

.feedback-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
}

.feedback-decorator {
  position: absolute;
  top: 0;
  right: 0;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(16,185,129,0.05);
  border-radius: 50%;
  margin-top: -128rpx;
  margin-right: -128rpx;
}

.feedback-header {
  margin-bottom: 48rpx;
}

.feedback-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.1);
}

.feedback-icon-box.success {
  background-color: #07C160;
  color: #fff;
}

.feedback-icon {
  font-size: 28px;
}

.feedback-title {
  font-size: 18px;
  color: rgba(0,0,0,0.9);
}

.feedback-sub {
  color: rgba(0,0,0,0.3);
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

/* Explanation */
.explanation-box {
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.explanation-marker {
  width: 8rpx;
  height: 48rpx;
  background-color: #07C160;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.explanation-content {
  flex: 1;
}

.explanation-label {
  color: rgba(0,0,0,1);
}

.explanation-text {
  font-size: 14px;
  color: rgba(0,0,0,0.7);
  line-height: 1.6;
}

/* Tip Card */
.tip-card {
  background-color: rgba(99,102,241,0.08);
  border-radius: 48rpx;
  padding: 40rpx;
  border: 2rpx solid rgba(99,102,241,0.1);
  gap: 32rpx;
}

.tip-icon-box {
  width: 112rpx;
  height: 112rpx;
  background-color: #fff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.tip-icon {
  font-size: 28px;
}

.tip-title {
  color: rgba(99,102,241,1);
}

.tip-sub {
  color: rgba(99,102,241,0.5);
}

/* End Button */
.end-btn {
  width: 100%;
  margin-top: 48rpx;
  padding: 40rpx;
  background-color: #1A1A1A;
  color: #fff;
  border-radius: 48rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.end-text {
  font-size: 15px;
}

.end-arrow {
  font-size: 20px;
}

/* ============ Answer Sheet Modal ============ */
.answer-sheet-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F8F8F8;
  z-index: 60;
  display: flex;
  flex-direction: column;
}

.modal-header-bar {
  height: 96rpx;
  background-color: #fff;
  border-bottom: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.modal-back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
}

.modal-back-icon {
  font-size: 24px;
  color: rgba(0,0,0,0.6);
}

.modal-title {
  font-size: 17px;
  flex: 1;
  text-align: center;
  margin-right: 80rpx;
}

.modal-scroll {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
}

.sheet-card {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

/* 状态说明 */
.status-legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 48rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 8rpx;
}

.legend-dot.done {
  background-color: rgba(16,185,129,0.15);
  border: 2rpx solid rgba(16,185,129,0.3);
}

.legend-dot.unanswered {
  background-color: #fff;
  border: 2rpx solid rgba(0,0,0,0.08);
}

.legend-text {
  font-size: 24rpx;
  color: rgba(0,0,0,0.6);
}

.sheet-header {
  margin-bottom: 48rpx;
}

.sheet-title {
  font-size: 18px;
  color: rgba(0,0,0,0.9);
}

/* Answer Grid - 5 columns */
.answer-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24rpx;
}

.answer-cell {
  aspect-ratio: 1;
  border-radius: 32rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.answer-cell.done {
  background-color: rgba(16,185,129,0.1);
  border-color: rgba(16,185,129,0.2);
}

.answer-num {
  font-size: 14px;
  color: rgba(0,0,0,0.2);
}

.answer-cell.done .answer-num {
  color: #07C160;
}

.answer-grid-empty {
  padding: 64rpx;
  text-align: center;
}

.empty-text {
  color: rgba(0,0,0,0.3);
  font-size: 14px;
}

.modal-footer {
  padding: 32rpx;
  background-color: #fff;
  border-top: 2rpx solid rgba(0,0,0,0.05);
}

.footer-row {
  display: flex;
  gap: 24rpx;
}

.continue-btn {
  flex: 1;
  padding: 32rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.continue-text {
  font-size: 14px;
  color: rgba(0,0,0,0.6);
}

.submit-exam-btn {
  flex: 2;
  padding: 32rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-exam-text {
  font-size: 14px;
}

/* ============ Unanswered Warning Modal ============ */
.warning-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.warning-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
}

.warning-card {
  position: relative;
  width: 600rpx;
  background-color: #fff;
  border-radius: 32rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.warning-icon-box {
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(251,191,36,0.1);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.warning-icon {
  font-size: 48rpx;
}

.warning-title {
  font-size: 32rpx;
  color: rgba(0,0,0,0.9);
  text-align: center;
  margin-bottom: 16rpx;
}

.warning-sub {
  font-size: 24rpx;
  color: rgba(0,0,0,0.5);
  text-align: center;
  margin-bottom: 48rpx;
}

.warning-buttons {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.warning-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.warning-btn.cancel {
  background-color: rgba(0,0,0,0.05);
}

.warning-btn.cancel .warning-btn-text {
  color: rgba(0,0,0,0.6);
}

.warning-btn.confirm {
  background-color: #07C160;
}

.warning-btn.confirm .warning-btn-text {
  color: #fff;
}

.warning-btn-text {
  font-size: 28rpx;
}

/* ============ Exam Result Report ============ */
.result-report {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F8F8F8;
  z-index: 100;
}

.result-scroll {
  height: 100vh;
  overflow-y: auto;
}

.result-content {
  padding: 64rpx;
  padding-bottom: 256rpx;
}

/* Trophy Header */
.result-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 64rpx;
}

.trophy-box {
  width: 192rpx;
  height: 192rpx;
  background-color: rgba(251,191,36,0.1);
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(251,191,36,0.2);
  margin-bottom: 32rpx;
}

.trophy-icon {
  font-size: 48px;
  color: #FBBF24;
}

.result-title {
  font-size: 28px;
  color: rgba(0,0,0,0.9);
}

.result-sub {
  color: rgba(0,0,0,0.3);
  letter-spacing: 16rpx;
  margin-top: 16rpx;
}

/* Score Card */
.score-card {
  background-color: #fff;
  border-radius: 80rpx;
  padding: 64rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  margin-bottom: 48rpx;
}

.score-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 64rpx;
}

.score-item {
  text-align: center;
  flex: 1;
}

.score-divider {
  width: 2rpx;
  height: 80rpx;
  background-color: rgba(0,0,0,0.03);
}

.score-label {
  color: rgba(0,0,0,0.2);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 36px;
  color: rgba(0,0,0,1);
}

.rate-high {
  color: #07C160;
}

/* AI Review Card */
.ai-review-card {
  background-color: rgba(99,102,241,0.08);
  border-radius: 64rpx;
  padding: 48rpx;
}

.ai-header {
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.ai-icon {
  font-size: 14px;
  color: #6366F1;
}

.ai-title {
  color: rgba(67,56,202,1);
}

.ai-text {
  color: rgba(99,102,241,0.6);
  line-height: 1.6;
}

/* Weak Topics Card */
.weak-card {
  background-color: #fff;
  border-radius: 80rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
  margin-bottom: 48rpx;
}

.weak-title {
  color: rgba(0,0,0,0.3);
  letter-spacing: 4rpx;
  margin-bottom: 48rpx;
  padding: 0 16rpx;
}

.weak-list {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  padding: 0 16rpx;
}

.weak-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.weak-top {
  justify-content: space-between;
}

.weak-label {
  color: rgba(0,0,0,0.7);
}

.weak-val {
  color: rgba(0,0,0,0.3);
}

.weak-bar {
  width: 100%;
  height: 12rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 12rpx;
  overflow: hidden;
}

.weak-fill {
  height: 100%;
  border-radius: 12rpx;
}

.weak-rose {
  background-color: #F43F5E;
}

.weak-amber {
  background-color: #FBBF24;
}

.weak-emerald {
  background-color: #07C160;
}

/* Result Actions */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.review-btn {
  width: 100%;
  padding: 40rpx;
  background-color: #1A1A1A;
  color: #fff;
  border-radius: 48rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.review-text {
  font-size: 16px;
}

.back-home-btn {
  width: 100%;
  padding: 32rpx;
  text-align: center;
}

.back-home-text {
  color: rgba(0,0,0,0.4);
}

/* ============ Utility Classes ============ */
.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: bold;
}

.text-small {
  font-size: 12px;
}

.text-xs {
  font-size: 10px;
}