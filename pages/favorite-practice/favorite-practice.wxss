/* pages/favorite-practice/favorite-practice.wxss - 收藏练习页面样式 */

.practice-page {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx;
  background-color: #fff;
  border-radius: 32rpx;
}

.loading-icon {
  font-size: 48rpx;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
}

.question-card {
  padding: 32rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.question-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.question-title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.85);
}

.question-count {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.5);
}

.header-left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.topic-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #DBEAFE;
}

.topic-badge .topic-text {
  color: #2563EB;
}

.difficulty-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #FEF3C7;
  color: #D97706;
}

.question-content {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.option-item.selected {
  background-color: #DBEAFE;
  border-color: #3B82F6;
}

.option-item.correct {
  background-color: #D1FAE5;
  border-color: #10B981;
}

.option-item.wrong {
  background-color: #FEE2E2;
  border-color: #EF4444;
}

.option-key {
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.option-item.selected .option-key {
  background-color: #3B82F6;
  color: #fff;
}

.option-item.correct .option-key {
  background-color: #10B981;
  color: #fff;
}

.option-item.wrong .option-key {
  background-color: #EF4444;
  color: #fff;
}

.option-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
  flex: 1;
}

.result-section {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.05);
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.result-header.success {
  color: #10B981;
}

.result-header.error {
  color: #EF4444;
}

.result-icon {
  font-size: 32rpx;
}

.result-text {
  font-size: 28rpx;
  font-weight: bold;
}

.answer-info {
  padding: 16rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.answer-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.answer-label {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.answer-value {
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 8rpx;
}

.answer-value.correct {
  color: #10B981;
}

.answer-value.wrong {
  color: #EF4444;
}

.explanation-box {
  padding: 16rpx;
  background-color: #FEF3C7;
  border-radius: 16rpx;
}

.explanation-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #92400E;
  margin-bottom: 8rpx;
}

.explanation-text {
  font-size: 24rpx;
  color: #78350F;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  justify-content: center;
  padding: 24rpx;
}

.submit-btn, .next-btn {
  padding: 24rpx 64rpx;
  border-radius: 32rpx;
}

.submit-text, .next-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.complete-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 48rpx;
}

.complete-icon-box {
  width: 160rpx;
  height: 160rpx;
  background-color: #D1FAE5;
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.complete-icon {
  font-size: 64rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(0, 0, 0, 0.85);
  margin-bottom: 16rpx;
}

.complete-stats {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 48rpx;
}

.complete-buttons {
  display: flex;
  gap: 24rpx;
}

.home-btn, .review-btn {
  padding: 24rpx 48rpx;
  border-radius: 32rpx;
}

.home-btn {
  background-color: #07C160;
}

.home-text, .review-btn-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.review-btn {
  background-color: rgba(0, 0, 0, 0.1);
}

.review-btn-text {
  color: rgba(0, 0, 0, 0.7);
}

.card {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.primary-bg {
  background-color: #07C160;
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-bold {
  font-weight: 700;
}

.text-muted {
  color: rgba(0, 0, 0, 0.4);
}