/* pages/records/records.wxss - 100%复刻 Records.tsx样式 */

.records-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* Header */
.records-header {
  padding: 48rpx;
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.header-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  border: 2rpx solid rgba(59, 130, 246, 0.1);
}

.header-icon-box.blue-bg {
  background-color: #DBEAFE;
}

.header-title {
  font-size: 20px;
  display: block;
}

.header-sub {
  display: block;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

/* Summary Stats */
.summary-stats {
  padding: 48rpx;
  border-radius: 64rpx;
  background-color: #1A1A1A;
  color: #fff;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.stat-decorator {
  position: absolute;
  right: 0;
  top: 0;
  width: 128rpx;
  height: 128rpx;
  background-color: rgba(59, 130, 246, 0.1);
  border-radius: 50%;
  opacity: 0.5;
}

.stat-box {
  position: relative;
  z-index: 1;
}

.stat-label {
  font-weight: 900;
  color: rgba(255,255,255,0.3);
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 24px;
  font-weight: 900 italic;
}

.stat-unit {
  font-size: 14px;
  font-weight: bold;
  color: #60A5FA;
}

/* Records List */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.record-item {
  padding: 40rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.record-score-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  background-color: rgba(0,0,0,0.02);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.record-type {
  font-size: 8px;
  font-weight: 900;
  color: rgba(0,0,0,0.2);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.record-score {
  font-size: 14px;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 14px;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 10px;
  font-weight: bold;
  color: rgba(0,0,0,0.3);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.record-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.result-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 8px;
  font-weight: 900;
  border: 2rpx solid rgba(251, 191, 36, 0.1);
}

.result-badge.excellent {
  background-color: #FEF3C7;
  color: #F59E0B;
}

/* Utility classes */
.card {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.card.dark {
  background-color: #1A1A1A;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-muted {
  color: #999;
}

.primary-color {
  color: #07C160;
}

.arrow {
  font-size: 24px;
  color: rgba(0,0,0,0.1);
}