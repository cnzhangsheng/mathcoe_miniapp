/* pages/records/records.wxss - 用户历史答题记录样式 */

.records-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* Filter Bar - 平铺筛选 */
.filter-bar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.filter-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background-color: rgba(0,0,0,0.03);
  border: 2rpx solid transparent;
}

.filter-option.active {
  background-color: rgba(7, 193, 96, 0.1);
  border-color: #07C160;
}

.filter-option.active .option-text {
  color: #07C160;
}

/* Records List */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.record-item {
  padding: 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.record-left {
  min-width: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-topic-box {
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  background-color: rgba(99, 102, 241, 0.1);
  border: 2rpx solid rgba(99, 102, 241, 0.2);
}

.record-topic-name {
  font-size: 24rpx;
  color: #6366F1;
  display: block;
  text-align: center;
}

.record-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: rgba(0,0,0,0.4);
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.record-info {
  flex: 1;
  min-width: 0;
}

.record-content {
}

.content-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.8);
  line-height: 1.5;
  word-wrap: break-word;
  word-break: break-all;
  white-space: pre-wrap;
}

.content-text p {
  margin: 0;
  line-height: 1.5;
  word-wrap: break-word;
  word-break: break-all;
}

.record-right {
  display: flex;
  align-items: center;
}

.result-badge {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 700;
  border: 2rpx solid;
}

.result-badge.excellent {
  background-color: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border-color: rgba(7, 193, 96, 0.2);
}

.result-badge.fail {
  background-color: rgba(244, 63, 94, 0.1);
  color: #F43F5E;
  border-color: rgba(244, 63, 94, 0.2);
}

/* Load More */
.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-more-text {
  color: rgba(0,0,0,0.3);
}

/* No More */
.no-more {
  padding: 32rpx;
  text-align: center;
}

.no-more-text {
  color: rgba(0,0,0,0.3);
}

/* Empty State */
.empty-state {
  padding: 64rpx;
  text-align: center;
}

.empty-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 80rpx 64rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  color: rgba(0,0,0,0.9);
  display: block;
  margin-bottom: 16rpx;
}

.empty-sub {
  color: rgba(0,0,0,0.5);
}

/* Utility classes */
.card {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.card.dark {
  background-color: #1A1A1A;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-muted {
  color: #999;
}

.primary-color {
  color: #07C160;
}