/* pages/index/index.wxss - 100%复刻 Home.tsx样式 */

.home-container {
  padding: 24rpx;
  padding-bottom: 120rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* User Header & Streak */
.user-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0,0,0,0.05);
  overflow: hidden;
  box-shadow: 0 0 0 8rpx rgba(7, 193, 96, 0.2);
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.login-time {
  color: rgba(0, 0, 0, 0.3);
  margin-top: 4rpx;
}

.user-greeting {
  font-size: 14px;
  color: rgba(0,0,0,0.9);
}

.user-sub {
  color: rgba(0,0,0,0.4);
}

.streak-badge {
  background-color: rgba(7, 193, 96, 0.1);
  color: #07C160;
  padding: 12rpx 24rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.1);
}

.streak-icon {
  font-size: 14px;
}

.streak-text {
  font-size: 11px;
}

/* Countdown Section */
.countdown-section {
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.countdown-bar {
  background-color: rgba(0,0,0,0.9);
  color: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 24rpx 48rpx rgba(0,0,0,0.2);
}

.countdown-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.timer-icon-box {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.countdown-label {
  color: rgba(255,255,255,0.5);
  letter-spacing: 4rpx;
  display: block;
}

.countdown-text {
  display: block;
  margin-top: 8rpx;
  font-size: 12px;
}

.signup-btn {
  background-color: #07C160;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
}

/* Daily Inspiration */
.inspiration-card {
  background-color: rgba(251, 191, 36, 0.05);
  border: 2rpx solid rgba(251, 191, 36, 0.5);
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-top: 24rpx;
}

.inspiration-icon-box {
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(251, 191, 36, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

.inspiration-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.inspiration-title {
  color: rgba(120, 53, 15, 1);
  line-height: 1;
}

.inspiration-quote {
  color: rgba(120, 53, 15, 0.6);
  font-style: italic;
  line-height: 1.5;
}

/* Primary Actions Grid */
.action-grid {
  display: flex;
  gap: 32rpx;
  margin-bottom: 24rpx;
}

.action-card {
  flex: 1;
  padding: 40rpx;
  border-radius: 56rpx;
  position: relative;
  overflow: hidden;
  min-height: 320rpx;
}

.action-decorator {
  position: absolute;
  right: -32rpx;
  top: -32rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.primary-decorator {
  background-color: rgba(7, 193, 96, 0.05);
}

.purple-decorator {
  background-color: rgba(168, 85, 247, 0.05);
}

.action-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-bottom: 32rpx;
}

.primary-icon {
  background-color: rgba(7, 193, 96, 0.1);
}

.purple-icon {
  background-color: rgba(168, 85, 247, 0.1);
}

.action-content {
  position: relative;
  z-index: 1;
}

.action-title {
  font-size: 16px;
  display: block;
  margin-bottom: 16rpx;
}

.progress-mini {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
}

.play-btn {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 12px;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.2);
}

.primary-bg {
  background-color: #07C160;
}

.purple-bg {
  background-color: #A855F7;
}

/* Capability Radar */
.radar-card {
  padding: 48rpx;
  border-radius: 64rpx;
  margin-bottom: 24rpx;
}

.radar-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.radar-icon-box {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(59, 130, 246, 0.1);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.radar-title {
  font-size: 16px;
}

.radar-rank {
  margin-left: auto;
}

.abilities-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
}

.ability-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ability-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx;
}

.ability-label {
  color: rgba(0,0,0,0.6);
}

.ability-value {
  color: rgba(0,0,0,0.3);
  font-family: monospace;
}

.ability-bar {
  height: 16rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 16rpx;
  overflow: hidden;
}

.ability-bar-fill {
  height: 100%;
  border-radius: 16rpx;
}

.bar-blue {
  background-color: rgba(59, 130, 246, 0.7);
}

.bar-purple {
  background-color: rgba(168, 85, 247, 0.7);
}

.bar-green {
  background-color: rgba(34, 197, 94, 0.7);
}

.bar-amber {
  background-color: rgba(251, 191, 36, 0.7);
}

/* Expert Tips */
.tips-section {
  margin-bottom: 24rpx;
}

.tips-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 16px;
  color: rgba(0,0,0,0.8);
}

.tips-sub {
  color: rgba(0,0,0,0.4);
  letter-spacing: -2rpx;
}

.tips-grid {
  display: flex;
  gap: 24rpx;
  padding: 0 4rpx;
}

.tip-card {
  flex: 1;
  padding: 32rpx;
  padding-top: 40rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.tip-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.05);
}

.tip-icon {
  font-size: 20px;
  color: #fff;
}

.tip-bg-indigo {
  background-color: rgba(99, 102, 241, 1);
}

.tip-bg-rose {
  background-color: rgba(244, 63, 94, 1);
}

.tip-bg-emerald {
  background-color: rgba(16, 185, 129, 1);
}

.tip-title {
  margin-bottom: 8rpx;
  color: rgba(0,0,0,0.9);
}

.tip-desc {
  color: rgba(0,0,0,0.3);
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Learning Journey / Progress Forest */
.forest-card {
  background: linear-gradient(135deg, rgba(220, 252, 231, 1) 0%, rgba(209, 250, 229, 1) 100%);
  border: 2rpx solid rgba(220, 252, 231, 0.5);
  border-radius: 64rpx;
  padding: 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  margin-left: 8rpx;
  margin-right: 8rpx;
}

.forest-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.forest-title {
  font-size: 16px;
  color: rgba(6, 78, 59, 1);
  line-height: 1;
}

.forest-progress {
  color: rgba(6, 78, 59, 0.5);
}

.forest-dots {
  display: flex;
  gap: -8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.forest-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  margin-right: 8rpx;
}

.forest-dot.filled {
  background-color: rgba(16, 185, 129, 1);
}

.forest-dot.empty {
  background-color: rgba(16, 185, 129, 0.2);
}

.forest-btn {
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(16, 185, 129, 1);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  box-shadow: 0 16rpx 32rpx rgba(16, 185, 129, 0.2);
}

/* Grid Navigation */
.nav-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.nav-card {
  padding: 48rpx;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  min-height: 160rpx;
}

.nav-icon-box {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}

.blue-icon {
  background-color: rgba(59, 130, 246, 0.1);
}

.red-icon {
  background-color: rgba(239, 68, 68, 0.1);
}

.nav-content {
  flex: 1;
}

.nav-title {
  font-size: 16px;
  display: block;
}

.nav-sub {
  margin-top: 8rpx;
  display: block;
}

.nav-arrow {
  font-size: 20px;
  color: rgba(0,0,0,0.1);
}

/* Past Years' Exams */
.exams-section {
  padding-bottom: 32rpx;
}

.exams-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.exams-title {
  font-size: 16px;
  color: rgba(0,0,0,0.8);
}

.exams-sub {
  color: rgba(0,0,0,0.4);
  letter-spacing: -2rpx;
}

.exams-scroll {
  display: flex;
  gap: 24rpx;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.exam-card {
  display: inline-flex;
  flex-direction: column;
  width: 256rpx;
  padding: 32rpx;
  border-radius: 32rpx;
}

.exam-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-bottom: 24rpx;
}

.exam-title {
  font-size: 14px;
  display: block;
  margin-bottom: 8rpx;
}

.exam-diff {
  display: block;
}

/* Utility classes */
.card {
  background-color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-xs {
  font-size: 9px;
}

.text-muted {
  color: rgba(0,0,0,0.4);
}

.primary-color {
  color: #07C160;
}