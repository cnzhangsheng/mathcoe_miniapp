/* pages/index/index.wxss - 新首页样式 */

.home-page {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 32rpx;
  padding-bottom: 120rpx;
}

/* Loading State */
.loading-state {
  min-height: calc(100vh - 64rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 80rpx 64rpx;
  text-align: center;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.loading-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 48rpx;
}

.loading-icon {
  font-size: 80rpx;
}

.loading-text {
  color: rgba(0, 0, 0, 0.5);
}

/* User Header */
.user-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-greeting {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
}

.user-sub {
  color: rgba(0, 0, 0, 0.5);
}

.streak-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background-color: rgba(251, 191, 36, 0.1);
  border-radius: 32rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.2);
}

.streak-icon {
  font-size: 28rpx;
}

.streak-text {
  font-size: 28rpx;
  color: #F59E0B;
}

/* Goal Section */
.goal-section {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.goal-header {
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.goal-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background-color: rgba(7, 193, 96, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.goal-icon-box text {
  font-size: 32rpx;
}

.goal-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.goal-count {
  color: rgba(0, 0, 0, 0.5);
  margin-left: auto;
}

.goal-progress-bar {
  height: 16rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 8rpx;
  overflow: hidden;
}

.goal-progress-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.goal-hint {
  margin-top: 16rpx;
  text-align: center;
}

.goal-complete {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.goal-complete-icon {
  font-size: 28rpx;
}

.goal-complete-text {
  color: #07C160;
}

/* Quick Actions */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.action-item {
  background-color: #fff;
  border-radius: 32rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.action-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-icon {
  background-color: rgba(7, 193, 96, 0.15);
}

.purple-icon {
  background-color: rgba(99, 102, 241, 0.15);
}

.amber-icon {
  background-color: rgba(251, 191, 36, 0.15);
}

.rose-icon {
  background-color: rgba(244, 63, 94, 0.15);
}

.action-icon {
  font-size: 32rpx;
}

.action-title {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.9);
}

.action-sub {
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.4);
}

/* Countdown Card */
.countdown-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: rgba(99, 102, 241, 0.05);
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.1);
}

.countdown-left {
  gap: 24rpx;
}

.timer-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.timer-icon-box text {
  font-size: 32rpx;
}

.countdown-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.countdown-label {
  color: rgba(0, 0, 0, 0.5);
}

.countdown-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.8);
}

.countdown-num {
  font-size: 32rpx;
}

.countdown-btn {
  padding: 16rpx 32rpx;
  background-color: #6366F1;
  border-radius: 24rpx;
}

.countdown-btn-text {
  color: #fff;
}

/* Radar Card */
.radar-card {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.radar-header {
  margin-bottom: 24rpx;
}

.radar-title-row {
  gap: 16rpx;
}

.radar-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.radar-icon-box text {
  font-size: 24rpx;
}

.radar-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.radar-rank {
  color: rgba(0, 0, 0, 0.5);
}

/* Radar Chart Container */
.radar-chart-container {
  width: 100%;
  height: 480rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.radar-canvas {
  width: 480rpx;
  height: 480rpx;
}

.abilities-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.ability-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ability-header {
  margin-bottom: 4rpx;
}

.ability-label {
  color: rgba(0, 0, 0, 0.7);
}

.ability-value {
  color: rgba(0, 0, 0, 0.4);
}

.ability-bar {
  height: 12rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 6rpx;
  overflow: hidden;
}

.ability-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.bar-blue {
  background-color: #6366F1;
}

.bar-purple {
  background-color: #A855F7;
}

.bar-green {
  background-color: #07C160;
}

.bar-amber {
  background-color: #F59E0B;
}

.bar-rose {
  background-color: #F43F5E;
}

/* Section Header */
.section-header {
  margin-bottom: 24rpx;
}

.section-title-row {
  gap: 16rpx;
}

.section-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-icon-box text {
  font-size: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.section-more {
  color: rgba(0, 0, 0, 0.4);
}

/* Recommend Section */
.recommend-section {
  margin-bottom: 24rpx;
}

.exam-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.exam-card {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 32rpx;
  gap: 24rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.exam-left {
  flex-shrink: 0;
}

.exam-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.exam-icon-box.daily {
  background-color: rgba(7, 193, 96, 0.15);
}

.exam-icon-box.mock {
  background-color: rgba(251, 191, 36, 0.15);
}

.exam-icon-box.topic {
  background-color: rgba(99, 102, 241, 0.15);
}

.exam-icon {
  font-size: 32rpx;
}

.exam-middle {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.exam-top {
  gap: 12rpx;
  align-items: center;
}

.level-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background-color: #07C160;
}

.level-text {
  font-size: 20rpx;
  color: #fff;
}

.exam-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.exam-bottom {
  gap: 24rpx;
}

.exam-meta {
  color: rgba(0, 0, 0, 0.4);
}

.exam-right {
  flex-shrink: 0;
}

.start-btn {
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
}

.start-text {
  color: #fff;
}

/* Stats Section */
.stats-section {
  margin-bottom: 24rpx;
}

.stats-header {
  padding: 16rpx 0;
}

.stats-title-row {
  gap: 8rpx;
}

.stats-icon-box {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
}

.stats-week {
  color: rgba(0, 0, 0, 0.4);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background-color: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.stat-item {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-value {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
}

.stat-label {
  color: rgba(0, 0, 0, 0.4);
}

.primary-color {
  color: #07C160;
}

.rose-color {
  color: #F43F5E;
}

.amber-color {
  color: #F59E0B;
}

/* Suggestion Card */
.suggestion-card {
  background-color: rgba(251, 191, 36, 0.05);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.1);
}

.suggestion-header {
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.suggestion-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.suggestion-icon-box text {
  font-size: 24rpx;
}

.suggestion-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.suggestion-content {
  margin-bottom: 24rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.7);
  line-height: 1.5;
}

.suggestion-highlight {
  color: #F59E0B;
}

.suggestion-btn {
  display: inline-flex;
  padding: 16rpx 32rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.suggestion-btn-text {
  font-size: 26rpx;
  color: #F59E0B;
}

/* Login Prompt */
.login-prompt {
  min-height: calc(100vh - 64rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.prompt-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 80rpx 64rpx;
  text-align: center;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  max-width: 600rpx;
}

.prompt-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: rgba(7, 193, 96, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 48rpx;
}

.prompt-icon {
  font-size: 80rpx;
}

.prompt-title {
  font-size: 40rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.prompt-sub {
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 48rpx;
}

.prompt-btn {
  padding: 32rpx 64rpx;
  background-color: #07C160;
  border-radius: 48rpx;
  display: inline-block;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, 0.2);
}

.prompt-btn-text {
  font-size: 32rpx;
  color: #fff;
}

/* Utility Classes */
.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-bold {
  font-weight: 700;
}

.text-small {
  font-size: 24rpx;
}

.text-muted {
  color: rgba(0, 0, 0, 0.5);
}

.primary-bg {
  background-color: #07C160;
}

.primary-color {
  color: #07C160;
}