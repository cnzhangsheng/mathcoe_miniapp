/* pages/game/sudoku/sudoku.wxss - 100%复刻 Sudoku.tsx样式 */

.sudoku-container {
  min-height: 100vh;
  background-color: #F8F8F8;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

/* Header */
.game-header {
  justify-content: space-between;
}

.header-btn {
  width: 80rpx;
  height: 80rpx;
  background-color: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  color: rgba(0,0,0,0.6);
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.header-title {
  font-size: 18px;
  color: rgba(0,0,0,0.9);
}

/* Sudoku Card */
.sudoku-card {
  padding: 32rpx;
  border-radius: 64rpx;
  overflow: hidden;
}

.sudoku-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  border: 4rpx solid rgba(0,0,0,0.1);
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #fff;
}

.sudoku-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(0,0,0,0.05);
  transition: all 0.2s;
}

.sudoku-cell.selected {
  background-color: rgba(7, 193, 96, 0.1);
  box-shadow: inset 0 0 0 4rpx #07C160;
  z-index: 10;
}

.sudoku-cell.initial {
  color: rgba(0,0,0,0.8);
}

.sudoku-cell.editable {
  color: rgba(59, 130, 246, 1);
}

.sudoku-cell.alt-block {
  background-color: rgba(0,0,0,0.02);
}

.sudoku-cell.row-border {
  border-bottom: 4rpx solid rgba(0,0,0,0.1);
}

.sudoku-cell.col-border {
  border-right: 4rpx solid rgba(0,0,0,0.1);
}

.cell-text {
  font-size: 18px;
}

.text-blue {
  color: rgba(59, 130, 246, 1);
}

/* Number Pad */
.number-pad {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 24rpx;
}

.num-btn {
  aspect-ratio: 1;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: rgba(0,0,0,0.6);
}

.num-text {
  font-size: 18px;
}

/* Action Buttons */
.action-row {
  gap: 32rpx;
}

.action-btn {
  flex: 1;
  padding: 32rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: rgba(0,0,0,0.6);
}

.action-icon {
  font-size: 20px;
}

/* Win Modal */
.win-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #F8F8F8;
  z-index: 50;
  display: flex;
  flex-direction: column;
}

.win-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
  gap: 64rpx;
}

.win-icon-box.amber {
  position: relative;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(251, 191, 36, 0.1);
  border-radius: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64px;
  box-shadow: 0 32rpx 64rpx rgba(251, 191, 36, 0.2);
}

.win-badge {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  border: 8rpx solid #fff;
}

.win-text {
  text-align: center;
}

.win-title {
  font-size: 30px;
  display: block;
}

.win-sub {
  letter-spacing: 4rpx;
  display: block;
  margin-top: 16rpx;
}

.result-card {
  padding: 64rpx;
  border-radius: 64rpx;
  width: 100%;
  max-width: 600rpx;
}

.result-row {
  justify-content: space-between;
  margin-bottom: 48rpx;
}

.level-badge {
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(59, 130, 246, 0.1);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(59, 130, 246, 1);
}

.result-label {
  color: rgba(0,0,0,0.8);
}

.divider {
  height: 2rpx;
  background-color: rgba(0,0,0,0.03);
  margin-bottom: 48rpx;
}

.result-quote {
  text-align: center;
  color: rgba(0,0,0,0.4);
  line-height: 1.5;
  font-size: 13px;
}

.win-footer {
  padding: 48rpx;
  background-color: #fff;
  border-top: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.win-btn {
  width: 100%;
  padding: 40rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  box-shadow: 0 32rpx 64rpx rgba(7, 193, 96, 0.2);
}

.win-btn-secondary {
  width: 100%;
  padding: 32rpx;
  color: rgba(0,0,0,0.4);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
}

/* Utility classes */
.card {
  background-color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-muted {
  color: rgba(0,0,0,0.4);
}

.primary-color {
  color: #07C160;
}

.primary-bg {
  background-color: #07C160;
  color: #fff;
}