/* pages/topic-question-detail/topic-question-detail.wxss - 100%复刻 kangaroo-math-brain TopicDetail.tsx */

.topic-detail-page {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 32rpx;
}

/* Empty State */
.empty-state {
  min-height: calc(100vh - 64rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-card, .complete-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 80rpx 64rpx;
  text-align: center;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  max-width: 600rpx;
}

.empty-icon-box, .complete-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 48rpx;
}

.complete-icon-box {
  background-color: rgba(16, 185, 129, 0.1);
}

.empty-icon, .complete-icon {
  font-size: 80rpx;
}

.empty-title, .complete-title {
  font-size: 36rpx;
  color: rgba(0, 0, 0, 0.9);
  margin-bottom: 16rpx;
}

.empty-sub, .complete-sub {
  color: rgba(0, 0, 0, 0.5);
  margin-bottom: 80rpx;
}

.empty-btn, .complete-btn {
  padding: 32rpx 64rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 48rpx;
  display: inline-block;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, 0.2);
}

.complete-btn {
  background-color: #000;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.2);
}

.empty-btn-text, .complete-btn-text {
  font-size: 28rpx;
}

/* Question Info Row - 题目信息行 */
.question-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.topic-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #DBEAFE;
  color: #2563EB;
}

.difficulty-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #FEF3C7;
  color: #D97706;
}

.question-type-badge {
  color: rgba(0, 0, 0, 0.5);
}

/* Question Card */
.question-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

/* Question Content Box - rich-text */
.question-content-box {
  margin-bottom: 32rpx;
}

.question-content {
  font-size: 36rpx;
  color: rgba(0, 0, 0, 0.9);
  line-height: 1.6;
}

/* rich-text 内部样式 */
.question-content p {
  margin: 0;
  line-height: 1.6;
}

/* Image Area */
.image-area {
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.question-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 32rpx;
}

/* Options List */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  position: relative;
  padding: 32rpx 48rpx;
  border-radius: 48rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.03);
  background-color: #fff;
  display: flex;
  align-items: center;
  gap: 32rpx;
  transition: all 0.2s;
}

.option-item.selected {
  background-color: rgba(99, 102, 241, 0.1);
  border-color: #6366F1;
  box-shadow: 0 8rpx 16rpx rgba(99, 102, 241, 0.1);
}

.option-item.correct {
  background-color: rgba(16, 185, 129, 0.1);
  border-color: #10B981;
  box-shadow: 0 8rpx 16rpx rgba(16, 185, 129, 0.1);
}

.option-item.wrong {
  background-color: rgba(244, 63, 94, 0.1);
  border-color: #F43F5E;
  box-shadow: 0 8rpx 16rpx rgba(244, 63, 94, 0.1);
}

.option-label-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.05);
}

.option-label-box.active {
  background-color: #6366F1;
}

.option-label-box.correct-label {
  background-color: #10B981;
}

.option-label-box.wrong-label {
  background-color: #F43F5E;
}

.option-label {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.3);
}

.option-label-box.active .option-label,
.option-label-box.correct-label .option-label,
.option-label-box.wrong-label .option-label {
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.3);
  line-height: 1.5;
}

/* rich-text 选项样式 */
.option-text p {
  margin: 0;
  line-height: 1.5;
}

.option-item.selected .option-text,
.option-item.correct .option-text,
.option-item.wrong .option-text {
  color: rgba(0, 0, 0, 0.8);
}

.option-status {
  margin-left: auto;
  font-size: 40rpx;
  color: #10B981;
}

.option-status.wrong-status {
  color: #F43F5E;
}

/* Submit Section - Action Bar */
.action-icons-right {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 24rpx;
  padding-right: 32rpx;
}

/* Submit Answer Row - 提交答案按钮单独一行 */
.submit-row {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
}

.submit-answer-btn {
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.2);
}

.submit-answer-btn.active {
  background-color: #07C160;
  color: #fff;
}

.submit-answer-btn.disabled {
  background-color: rgba(0, 0, 0, 0.05);
  color: rgba(0, 0, 0, 0.3);
  box-shadow: none;
}

.submit-answer-text {
  font-size: 28rpx;
}

.action-icon-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  border-radius: 32rpx;
  background-color: rgba(0, 0, 0, 0.03);
}

.action-icon-btn.liked {
  background-color: rgba(99, 102, 241, 0.1);
}

.action-icon-btn.bookmarked {
  background-color: rgba(251, 191, 36, 0.1);
}

.action-icon {
  font-size: 28rpx;
}

.action-count {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.action-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.action-icon-btn.bookmarked .action-text {
  color: #F59E0B;
}

/* Analysis Section */
.analysis-section {
  margin-top: 48rpx;
}

.analysis-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.analysis-icon {
  font-size: 32rpx;
  color: #F59E0B;
}

.analysis-title {
  color: rgba(0, 0, 0, 0.6);
  letter-spacing: 4rpx;
}

.analysis-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 64rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.analysis-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 128rpx;
  height: 128rpx;
  background-color: rgba(16, 185, 129, 0.05);
  border-radius: 50%;
  transform: translate(64rpx, -64rpx);
}

/* Answer Row */
.answer-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.answer-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 40rpx;
  background-color: #10B981;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(16, 185, 129, 0.2);
}

.answer-letter {
  font-size: 40rpx;
  color: #fff;
}

.answer-info {
  display: flex;
  flex-direction: column;
}

.answer-title {
  font-size: 36rpx;
  color: rgba(0, 0, 0, 0.9);
}

.answer-sub {
  color: #07C160;
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

/* Logic Box */
.logic-box {
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 48rpx;
  padding: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.logic-label {
  color: rgba(0, 0, 0, 0.3);
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.logic-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.7);
  line-height: 1.6;
}

/* Tip Row */
.tip-row {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
  padding: 16rpx;
  margin-bottom: 40rpx;
}

.tip-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-icon {
  font-size: 40rpx;
  color: #6366F1;
}

.tip-content {
  flex: 1;
}

.tip-title {
  color: rgba(0, 0, 0, 0.8);
  margin-bottom: 8rpx;
}

.tip-text {
  color: rgba(0, 0, 0, 0.5);
  line-height: 1.5;
}

/* Key Point Box */
.key-point-box {
  background-color: rgba(251, 191, 36, 0.1);
  border-radius: 48rpx;
  padding: 40rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.2);
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.key-icon-box {
  width: 96rpx;
  height: 96rpx;
  background-color: #fff;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(251, 191, 36, 0.2);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.05);
}

.key-icon {
  font-size: 48rpx;
  color: #F59E0B;
}

.key-content {
  flex: 1;
}

.key-label {
  color: rgba(180, 83, 9, 1);
  margin-bottom: 8rpx;
}

.key-text {
  color: rgba(180, 83, 9, 0.7);
}

/* Next Section */
.next-section {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
}

.next-btn {
  padding: 24rpx 64rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.2);
}

.next-text {
  font-size: 28rpx;
}

/* Utility Classes */
.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 24rpx;
}

.text-xs {
  font-size: 20rpx;
}