/* pages/answer-sheet/answer-sheet.wxss */

.answer-sheet-page {
  min-height: 100vh;
  background-color: #F8F8F8;
  display: flex;
  flex-direction: column;
}

/* Header */
.modal-header-bar {
  height: 96rpx;
  background-color: #fff;
  border-bottom: 2rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.modal-back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -16rpx;
}

.modal-back-icon {
  font-size: 24px;
  color: rgba(0,0,0,0.6);
}

.modal-title {
  font-size: 17px;
  flex: 1;
  text-align: center;
  margin-right: 80rpx;
}

/* Scroll */
.modal-scroll {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
}

.sheet-card {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

/* 状态说明 */
.status-legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 48rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 8rpx;
}

.legend-dot.done {
  background-color: rgba(16,185,129,0.15);
  border: 2rpx solid rgba(16,185,129,0.3);
}

.legend-dot.unanswered {
  background-color: #fff;
  border: 2rpx solid rgba(0,0,0,0.08);
}

.legend-text {
  font-size: 24rpx;
  color: rgba(0,0,0,0.6);
}

/* Answer Grid - 5 columns */
.answer-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24rpx;
}

.answer-cell {
  aspect-ratio: 1;
  border-radius: 32rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.answer-cell.done {
  background-color: rgba(16,185,129,0.1);
  border-color: rgba(16,185,129,0.2);
}

.answer-num {
  font-size: 14px;
  color: rgba(0,0,0,0.2);
}

.answer-cell.done .answer-num {
  color: #07C160;
}

.answer-grid-empty {
  padding: 64rpx;
  text-align: center;
}

.empty-text {
  color: rgba(0,0,0,0.3);
  font-size: 14px;
}

/* Utility */
.text-bold {
  font-weight: bold;
}