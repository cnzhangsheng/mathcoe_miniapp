/* pages/review/review.wxss - 复习中心页面样式 */

.review-page {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

/* Loading State */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 48rpx;
  background-color: #fff;
  border-radius: 32rpx;
}

.loading-icon-box {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  font-size: 32rpx;
}

.loading-text {
  color: rgba(0, 0, 0, 0.4);
}

/* Page Header */
.page-header {
  padding: 24rpx 16rpx;
  margin-bottom: 16rpx;
}

.header-title-row {
  gap: 12rpx;
}

.header-icon-box {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  font-size: 36rpx;
  color: rgba(0, 0, 0, 0.9);
}

/* Tabs */
.tabs-wrapper {
  margin-bottom: 24rpx;
}

.tabs-container {
  display: flex;
  gap: 16rpx;
  padding: 12rpx;
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 44rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid rgba(0, 0, 0, 0.05);
}

.tab-item:not(.active) {
  color: rgba(0, 0, 0, 0.3);
}

.tab-icon {
  font-size: 28rpx;
}

.tab-text {
  font-size: 28rpx;
}

.tab-count {
  padding: 4rpx 12rpx;
  background-color: #EF4444;
  color: #fff;
  border-radius: 12rpx;
  font-size: 20rpx;
}

/* Stats Card */
.stats-card {
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 32rpx;
}

.stat-item {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-value {
  font-size: 44rpx;
}

.stat-label {
  color: rgba(0, 0, 0, 0.4);
}

/* Action Bar */
.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

/* Filter Bar */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.filter-item.active {
  background-color: #fff;
  border-color: #07C160;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.15);
}

.filter-item:not(.active) {
  color: rgba(0, 0, 0, 0.5);
}

.filter-icon {
  font-size: 20rpx;
}

.filter-text {
  color: rgba(0, 0, 0, 0.7);
}

.filter-item.active .filter-text {
  color: #07C160;
}

/* Filter Row - 筛选按钮行 */
.filter-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
  flex-wrap: wrap;
}

.filter-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 16rpx 20rpx;
  min-width: 80rpx;
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.filter-btn.active {
  background-color: #fff;
  border-color: #07C160;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.15);
}

.filter-btn-icon {
  font-size: 24rpx;
}

.filter-btn-text {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.7);
}

.filter-btn.active .filter-btn-text {
  color: #07C160;
}

/* Start Button - 开始复习按钮 */
.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.2);
}

.start-btn-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 32rpx;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
}

.action-btn.primary-bg {
  background-color: #07C160;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.2);
}

.action-btn.outline-btn {
  background-color: #fff;
  border-color: rgba(0, 0, 0, 0.1);
  color: rgba(0, 0, 0, 0.7);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 28rpx;
}

/* Section Card */
.section-card {
  margin-bottom: 24rpx;
}

.section-header {
  padding: 24rpx;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.03);
}

.section-title-row {
  gap: 12rpx;
}

.section-icon-box {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.9);
}

.section-more {
  color: rgba(0, 0, 0, 0.4);
}

/* Topic List */
.topic-list {
  padding: 16rpx;
}

.topic-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  margin-bottom: 12rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 24rpx;
}

.topic-left {
  gap: 16rpx;
}

.topic-icon-box {
  width: 56rpx;
  height: 56rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.topic-icon-box.blue-bg {
  background-color: #DBEAFE;
}

.topic-icon-box.purple-bg {
  background-color: #E9D5FF;
}

.topic-icon-box.green-bg {
  background-color: #D1FAE5;
}

.topic-icon-box.amber-bg {
  background-color: #FEF3C7;
}

.topic-icon-box.rose-bg {
  background-color: #FFE4E6;
}

.topic-icon-box.gray-bg {
  background-color: #F3F4F6;
}

.topic-icon {
  font-size: 28rpx;
}

.topic-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.topic-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
}

.topic-count {
  color: rgba(0, 0, 0, 0.4);
}

.topic-right .review-btn {
  padding: 12rpx 24rpx;
  background-color: #07C160;
  border-radius: 20rpx;
}

.review-text {
  color: #fff;
}

/* Question List */
.question-list {
  padding: 16rpx;
}

.question-item {
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
}

.question-top {
  margin-bottom: 16rpx;
}

.question-meta {
  gap: 12rpx;
}

.topic-badge {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background-color: #DBEAFE;
}

.topic-badge .topic-text {
  color: #2563EB;
}

.question-date {
  color: rgba(0, 0, 0, 0.4);
}

.question-content-box {
  margin-bottom: 16rpx;
}

.question-content {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.question-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.retry-info .retry-text {
  color: rgba(0, 0, 0, 0.4);
}

.question-actions {
  gap: 12rpx;
}

.mini-btn {
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
}

.mini-btn.primary-bg {
  background-color: #1A1A1A;
}

.mini-btn.outline-btn {
  background-color: rgba(0, 0, 0, 0.05);
}

.mini-btn.primary-bg .mini-text {
  color: #fff;
}

.mini-btn.outline-btn .mini-text {
  color: rgba(0, 0, 0, 0.6);
}

.remove-btn {
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}

.practice-btn {
  padding: 16rpx 32rpx;
  border-radius: 20rpx;
}

.practice-text {
  color: #fff;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon-box {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.3);
}

.empty-sub {
  color: rgba(0, 0, 0, 0.2);
  margin-top: 8rpx;
}

/* Load More */
.load-more {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.load-more-text {
  color: rgba(0, 0, 0, 0.4);
}

/* End Tip */
.end-tip {
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.end-tip-text {
  color: rgba(0, 0, 0, 0.3);
}

/* Utility Classes */
.card {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-bold {
  font-weight: 700;
}

.text-small {
  font-size: 24rpx;
}

.text-muted {
  color: rgba(0, 0, 0, 0.4);
}

.primary-color {
  color: #07C160;
}

.primary-bg {
  background-color: #07C160;
}

.rose-color {
  color: #F43F5E;
}

.amber-color {
  color: #F59E0B;
}