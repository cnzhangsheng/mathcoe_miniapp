/* pages/review/review.wxss - 100%复刻 Review.tsx样式 */

.review-container {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
}

/* Tabs */
.tabs-wrapper {
  margin-bottom: 32rpx;
}

.tabs-container {
  display: flex;
  gap: 16rpx;
  padding: 12rpx;
  background-color: rgba(0,0,0,0.03);
  border-radius: 44rpx;
  border: 2rpx solid rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
  border: 2rpx solid rgba(0,0,0,0.05);
}

.tab-item:not(.active) {
  color: rgba(0,0,0,0.3);
}

.tab-icon {
  font-size: 12px;
}

.tab-text {
  font-size: 11px;
  font-weight: 900;
}

/* Error Analysis Card */
.error-analysis {
  padding: 48rpx;
  border-radius: 64rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.error-analysis::before {
  content: '';
  position: absolute;
  right: -16rpx;
  top: -16rpx;
  width: 96rpx;
  height: 96rpx;
  background-color: #FFE4E6;
  border-radius: 0 0 0 120rpx;
  opacity: 0.5;
}

.analysis-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.analysis-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
}

.analysis-icon-box.rose-bg {
  background-color: #FFE4E6;
}

.analysis-title {
  font-size: 16px;
  display: block;
}

.analysis-sub {
  display: block;
  margin-top: 8rpx;
}

/* Chart */
.chart-container {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 192rpx;
  padding: 0 16rpx;
  margin-bottom: 32rpx;
}

.chart-bar-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.chart-bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  background-color: rgba(0,0,0,0.05);
}

.chart-bar.highlight {
  background-color: #EF4444;
}

.chart-label {
  font-size: 8px;
  font-weight: 900;
  color: rgba(0,0,0,0.2);
}

/* Diagnosis Box */
.diagnosis-box {
  padding: 32rpx;
  background-color: rgba(254, 242, 242, 0.5);
  border-radius: 32rpx;
  border: 2rpx solid #FECACA;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.diagnosis-icon {
  font-size: 16px;
  color: #EF4444;
}

.diagnosis-text {
  font-size: 11px;
  font-weight: bold;
  color: #881337;
  line-height: 1.6;
}

.underline {
  text-decoration: underline;
  text-decoration-color: #FCA5A5;
}

/* Smart Stats Card */
.smart-stats {
  padding: 48rpx;
  border-radius: 64rpx;
  background-color: #1A1A1A;
  color: #fff;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.smart-stats::before {
  content: '';
  position: absolute;
  left: -10%;
  bottom: -20%;
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(99, 102, 241, 0.1);
  border-radius: 50%;
}

.stats-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 64rpx;
}

.pulse-dots {
  display: flex;
  gap: 8rpx;
}

.pulse-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #07C160;
  border-radius: 50%;
}

.stats-title {
  font-size: 24px;
  font-weight: 900 italic;
  margin-top: 8rpx;
}

.highlight-num {
  color: #07C160;
}

.stats-right {
  text-align: right;
}

.stats-label {
  font-size: 10px;
  font-weight: 900;
  color: rgba(255,255,255,0.4);
  margin-bottom: 8rpx;
  display: block;
}

.stats-value {
  font-size: 18px;
  font-weight: 900;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.primary-btn {
  flex: 1;
  padding: 32rpx;
  background-color: #07C160;
  border-radius: 32rpx;
  font-size: 14px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 16rpx 48rpx rgba(7, 193, 96, 0.2);
}

.secondary-btn {
  padding: 32rpx 40rpx;
  background-color: rgba(255,255,255,0.1);
  border-radius: 32rpx;
  font-size: 16px;
  border: 2rpx solid rgba(255,255,255,0.05);
}

/* Category Section */
.category-section {
  margin-bottom: 80rpx;
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.category-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 24rpx;
}

.category-icon-box.amber-bg {
  background-color: #FEF3C7;
  box-shadow: 0 8rpx 32rpx rgba(251, 191, 36, 0.1);
}

.category-icon-box.blue-bg {
  background-color: #DBEAFE;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.1);
}

.category-title {
  font-size: 16px;
  display: block;
}

.category-count {
  display: block;
  margin-top: 8rpx;
}

/* Question Card */
.question-card {
  padding: 40rpx;
  border-radius: 64rpx;
  margin-bottom: 32rpx;
}

.question-content {
  gap: 40rpx;
}

.question-img-wrapper {
  width: 224rpx;
  height: 224rpx;
  border-radius: 32rpx;
  overflow: hidden;
  border: 2rpx solid rgba(0,0,0,0.05);
  position: relative;
}

.question-img {
  width: 100%;
  height: 100%;
}

.difficulty-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 12rpx;
  background-color: rgba(0,0,0,0.6);
  border-radius: 8rpx;
  font-size: 8px;
  font-weight: 900;
  color: rgba(255,255,255,0.9);
}

.question-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.status-critical {
  font-size: 10px;
  font-weight: 900;
  color: #EF4444;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-warning {
  font-size: 10px;
  font-weight: 900;
  color: #F59E0B;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-icon {
  font-size: 10px;
}

.question-id {
  font-size: 9px;
  font-weight: bold;
  color: rgba(0,0,0,0.2);
  font-style: italic;
}

.question-title {
  font-size: 14px;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.progress-bar-wrapper {
  margin-bottom: 24rpx;
}

.progress-bar-bg {
  height: 8rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 8rpx;
}

.progress-bar-fill.rose {
  background-color: #EF4444;
}

.progress-bar-fill.amber {
  background-color: #F59E0B;
}

.error-reason-box {
  padding: 16rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 8rpx;
  font-size: 9px;
  font-weight: bold;
  color: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* Question Actions */
.question-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid rgba(0,0,0,0.03);
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 11px;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.action-btn.primary {
  background-color: #1A1A1A;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
}

.action-btn.secondary {
  background-color: rgba(0,0,0,0.05);
  color: rgba(0,0,0,0.6);
}

.action-icon {
  font-size: 14px;
}

.action-icon.purple {
  color: #7C3AED;
}

.delete-btn {
  width: 96rpx;
  height: 96rpx;
  background-color: rgba(0,0,0,0.02);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: rgba(0,0,0,0.2);
}

/* Similar Tip */
.similar-tip {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: rgba(237, 233, 254, 0.3);
  border-radius: 32rpx;
  border: 2rpx dashed rgba(165, 180, 252, 0.5);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.similar-icon {
  font-size: 12px;
  color: #818CF8;
  margin-right: 16rpx;
}

.similar-text {
  font-size: 10px;
  font-weight: bold;
  color: #4F46E5;
}

.similar-link {
  font-size: 9px;
  font-weight: 900;
  color: #4F46E5;
}

/* Favorites */
.favorite-card {
  padding: 40rpx;
  border-radius: 64rpx;
  margin-bottom: 32rpx;
}

.favorite-content {
  gap: 32rpx;
}

.favorite-img-wrapper {
  width: 192rpx;
  height: 192rpx;
  border-radius: 32rpx;
  overflow: hidden;
  border: 2rpx solid rgba(0,0,0,0.05);
  position: relative;
}

.favorite-img {
  width: 100%;
  height: 100%;
}

.fav-difficulty-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 8rpx 12rpx;
  background-color: #EC4899;
  border-radius: 8rpx;
  font-size: 8px;
  font-weight: 900;
  color: #fff;
}

.favorite-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.fav-category-tag {
  padding: 8rpx 12rpx;
  background-color: #FDF2F8;
  border-radius: 8rpx;
  font-size: 9px;
  font-weight: 900;
  color: #EC4899;
  margin-bottom: 12rpx;
}

.favorite-title {
  font-size: 14px;
  line-height: 1.4;
}

.favorite-date {
  font-size: 10px;
  font-weight: bold;
  font-style: italic;
}

.favorite-actions {
  display: flex;
  gap: 24rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid rgba(0,0,0,0.03);
  margin-top: 32rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  text-align: center;
}

.empty-icon-box {
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(0,0,0,0.05);
  border-radius: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  color: rgba(0,0,0,0.1);
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 14px;
  font-weight: 900;
  color: rgba(0,0,0,0.2);
}

.empty-sub {
  font-size: 10px;
  font-weight: bold;
  color: rgba(0,0,0,0.1);
  margin-top: 8rpx;
}

/* Stats Card */
.stats-card {
  padding: 32rpx;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.stats-card .stats-title {
  font-size: 28rpx;
}

.stats-card .highlight-num {
  color: #07C160;
  font-size: 36rpx;
}

/* Question Header */
.question-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.question-header .difficulty-tag {
  position: static;
  padding: 8rpx 16rpx;
  background-color: rgba(0,0,0,0.1);
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: rgba(0,0,0,0.6);
}

.question-header .question-id {
  font-size: 22rpx;
  color: rgba(0,0,0,0.4);
}

/* Question Content Box */
.question-content-box {
  margin-bottom: 24rpx;
}

.question-content-box .question-content {
  font-size: 28rpx;
  color: rgba(0,0,0,0.85);
  line-height: 1.6;
}

/* Answer Info */
.answer-info {
  padding: 16rpx;
  background-color: rgba(0,0,0,0.02);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.answer-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.answer-label {
  font-size: 24rpx;
  color: rgba(0,0,0,0.5);
}

.answer-value {
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 8rpx;
}

.answer-value.correct {
  color: #07C160;
}

.answer-value.wrong {
  color: #EF4444;
}

/* Utility classes */
.card {
  background-color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.card.dark {
  background-color: #1A1A1A;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.2);
}

.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 10px;
}

.text-muted {
  color: #999;
}

.primary-color {
  color: #07C160;
}

.arrow {
  font-size: 24px;
  color: rgba(0,0,0,0.1);
}