<!--pages/review/review.wxml-->
<view class="review-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- Tabs -->
    <view class="tabs-wrapper">
      <view class="tabs-container">
        <view class="tab-item {{activeTab === 'incorrect' ? 'active' : ''}}" data-tab="incorrect" bindtap="switchTab">
          <text class="tab-icon">📝</text>
          <text class="tab-text">错题本</text>
        </view>
        <view class="tab-item {{activeTab === 'favorites' ? 'active' : ''}}" data-tab="favorites" bindtap="switchTab">
          <text class="tab-icon">❤️</text>
          <text class="tab-text">收藏夹</text>
        </view>
      </view>
    </view>

    <!-- 错题本 Tab -->
    <block wx:if="{{activeTab === 'incorrect'}}">
      <!-- Wrong Questions List -->
      <block wx:for="{{wrongQuestions}}" wx:key="id">
        <view class="question-card card" bindtap="viewWrongQuestion" data-index="{{index}}">
          <view class="question-header">
            <view class="delete-btn-red" data-id="{{item.question_id}}" catchtap="removeWrong">
              <text class="delete-text">删除</text>
            </view>
          </view>

          <view class="question-content-box">
            <rich-text class="question-content" nodes="{{item.content}}"></rich-text>
          </view>
        </view>
      </block>

      <!-- Empty State -->
      <block wx:if="{{wrongQuestions.length === 0}}">
        <view class="empty-state">
          <view class="empty-icon-box">
            <text>📝</text>
          </view>
          <text class="empty-title">暂无错题记录</text>
          <text class="empty-sub">继续练习，保持正确率！</text>
        </view>
      </block>
    </block>

    <!-- 收藏夹 Tab -->
    <block wx:if="{{activeTab === 'favorites'}}">
      <!-- Stats Card -->
      <view class="stats-card card">
        <text class="stats-title text-bold">收藏总数：<text class="highlight-num">{{favorites.length}}</text></text>
      </view>

      <!-- Favorites List -->
      <block wx:for="{{favorites}}" wx:key="id">
        <view class="favorite-card card" bindtap="viewFavorite" data-index="{{index}}">
          <view class="question-header">
            <view class="difficulty-tag">{{item.difficulty}}</view>
            <text class="question-id">#{{item.question_id}}</text>
          </view>

          <view class="question-content-box">
            <rich-text class="question-content" nodes="{{item.content}}"></rich-text>
          </view>

          <view class="favorite-actions">
            <view class="action-btn primary" data-id="{{item.question_id}}" catchtap="retryFavorite">
              <text class="action-icon">▶</text>
              <text>重新挑战</text>
            </view>
            <view class="delete-btn" data-id="{{item.question_id}}" catchtap="removeFavorite">
              <text>🗑️</text>
            </view>
          </view>
        </view>
      </block>

      <!-- Empty State -->
      <block wx:if="{{favorites.length === 0}}">
        <view class="empty-state">
          <view class="empty-icon-box">
            <text>⭐</text>
          </view>
          <text class="empty-title">暂无收藏题目</text>
          <text class="empty-sub">MARK QUESTIONS TO SEE THEM HERE</text>
        </view>
      </block>
    </block>
  </block>
</view>