<!--pages/review/review.wxml - 复习中心页面 -->
<view class="review-page">

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-card">
      <view class="loading-icon-box">
        <text class="loading-icon">🔄</text>
      </view>
      <text class="loading-text text-small">正在加载...</text>
    </view>
  </view>

  <block wx:if="{{!loading}}">
    <!-- Tab切换 -->
    <view class="tabs-wrapper">
      <view class="tabs-container">
        <view class="tab-item {{activeTab === 'wrong' ? 'active' : ''}}" bindtap="switchTab" data-tab="wrong">
          <text class="tab-icon">❌</text>
          <text class="tab-text text-bold">错题本</text>
        </view>
        <view class="tab-item {{activeTab === 'favorite' ? 'active' : ''}}" bindtap="switchTab" data-tab="favorite">
          <text class="tab-icon">⭐</text>
          <text class="tab-text text-bold">收藏夹</text>
        </view>
      </view>
    </view>

    <!-- 错题本内容 -->
    <block wx:if="{{activeTab === 'wrong'}}">
      <!-- 专题筛选 -->
      <view class="filter-row">
        <block wx:for="{{filterTopics}}" wx:key="id">
          <view class="filter-btn {{selectedTopicId === item.id ? 'active' : ''}}" bindtap="selectTopic" data-id="{{item.id}}">
            <text class="filter-btn-icon">{{item.icon}}</text>
            <text class="filter-btn-text">{{item.title}}</text>
          </view>
        </block>
      </view>

      <!-- 开始复习按钮 -->
      <view class="start-btn primary-bg" bindtap="startReview">
        <text class="start-btn-text">重新练习</text>
      </view>

      <!-- 错题列表 -->
      <view class="section-card card">
        <block wx:if="{{wrongQuestions.length > 0}}">
          <view class="question-list">
            <block wx:for="{{wrongQuestions}}" wx:key="id">
              <view class="question-item card" bindtap="viewWrongQuestion" data-question="{{item}}">
                <view class="question-top flex-between">
                  <view class="question-meta flex-row">
                    <view class="topic-badge">
                      <text class="topic-text text-small text-bold">{{item.topicTitle}}</text>
                    </view>
                    <text class="difficulty-badge text-small text-bold" wx:if="{{item.level}}">L{{item.level}}</text>
                    <text class="question-date text-small text-muted">{{item.dateLabel}}</text>
                  </view>
                  <view class="remove-btn" catchtap="removeWrong" data-id="{{item.question_id}}">
                    <text class="remove-icon">✕</text>
                  </view>
                </view>

                <view class="question-content-box">
                  <rich-text class="question-content" nodes="{{item.content}}"></rich-text>
                </view>
              </view>
            </block>
          </view>

          <!-- 加载更多提示 -->
          <view class="load-more" wx:if="{{wrongLoading}}">
            <text class="load-more-text text-small text-muted">加载中...</text>
          </view>

          <!-- 底部提示 -->
          <view class="end-tip" wx:if="{{!wrongHasMore && wrongQuestions.length > 0}}">
            <text class="end-tip-text text-small text-muted">——已经到底啦——</text>
          </view>
        </block>

        <!-- 空状态 -->
        <block wx:if="{{wrongQuestions.length === 0}}">
          <view class="empty-state">
            <view class="empty-icon-box">
              <text>🎉</text>
            </view>
            <text class="empty-title text-bold">暂无错题</text>
            <text class="empty-sub text-small text-muted">继续保持，加油！</text>
          </view>
        </block>
      </view>
    </block>

    <!-- 收藏夹内容 -->
    <block wx:if="{{activeTab === 'favorite'}}">
      <view class="section-card card">
        <block wx:if="{{favoriteQuestions.length > 0}}">
          <view class="question-list">
            <block wx:for="{{favoriteQuestions}}" wx:key="id">
              <view class="question-item card" bindtap="practiceFavorite" data-question="{{item}}">
                <view class="question-top flex-between">
                  <view class="question-meta flex-row">
                    <view class="topic-badge">
                      <text class="topic-text text-small text-bold">{{item.topicTitle}}</text>
                    </view>
                    <text class="difficulty-badge text-small text-bold" wx:if="{{item.level}}">L{{item.level}}</text>
                  </view>
                  <view class="remove-btn" catchtap="removeFavorite" data-id="{{item.question_id}}">
                    <text class="remove-icon">✕</text>
                  </view>
                </view>

                <view class="question-content-box">
                  <rich-text class="question-content" nodes="{{item.content}}"></rich-text>
                </view>
              </view>
            </block>
          </view>

          <!-- 加载更多提示 -->
          <view class="load-more" wx:if="{{favoriteLoading}}">
            <text class="load-more-text text-small text-muted">加载中...</text>
          </view>

          <!-- 底部提示 -->
          <view class="end-tip" wx:if="{{!favoriteHasMore && favoriteQuestions.length > 0}}">
            <text class="end-tip-text text-small text-muted">——已经到底啦——</text>
          </view>
        </block>

        <!-- 空状态 -->
        <block wx:if="{{favoriteQuestions.length === 0}}">
          <view class="empty-state">
            <view class="empty-icon-box">
              <text>⭐</text>
            </view>
            <text class="empty-title text-bold">暂无收藏</text>
            <text class="empty-sub text-small text-muted">练习时可点击收藏按钮添加</text>
          </view>
        </block>
      </view>
    </block>
  </block>
</view>