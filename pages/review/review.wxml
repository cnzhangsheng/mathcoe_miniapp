<!--pages/review/review.wxml-->
<view class="review-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 错题本按日期分组显示 -->
    <block wx:for="{{groupedQuestions}}" wx:key="date">
      <!-- 日期标题 -->
      <view class="date-header">
        <text class="date-title">{{item.dateLabel}}</text>
        <text class="date-count">{{item.questions.length}}题</text>
      </view>

      <!-- 该日期下的错题列表 -->
      <block wx:for="{{item.questions}}" wx:key="id" wx:for-item="question">
        <view class="question-card card" bindtap="viewWrongQuestion" data-question="{{question}}">
          <view class="question-header">
            <view class="delete-btn-red" data-id="{{question.question_id}}" catchtap="removeWrong">
              <text class="delete-text">删除</text>
            </view>
          </view>

          <view class="question-content-box">
            <rich-text class="question-content" nodes="{{question.content}}"></rich-text>
          </view>
        </view>
      </block>
    </block>

    <!-- Empty State -->
    <block wx:if="{{wrongQuestions.length === 0}}">
      <view class="empty-state">
        <view class="empty-icon-box">
          <text>📝</text>
        </view>
        <text class="empty-title">暂无错题记录</text>
        <text class="empty-sub">继续练习，保持正确率！</text>
      </view>
    </block>
  </block>
</view>