/* pages/record-detail/record-detail.wxss - 答题记录题目详情样式 */

.detail-page {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 32rpx;
}

/* Loading State */
.loading-state {
  min-height: calc(100vh - 64rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 80rpx 64rpx;
  text-align: center;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.loading-icon-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: rgba(99, 102, 241, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 48rpx;
}

.loading-icon {
  font-size: 80rpx;
}

.loading-text {
  color: rgba(0, 0, 0, 0.5);
}

/* Question Info Row */
.question-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.topic-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #DBEAFE;
  color: #2563EB;
}

.difficulty-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #FEF3C7;
  color: #D97706;
}

.question-type-badge {
  color: rgba(0, 0, 0, 0.5);
}

/* Question Card */
.question-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.question-content-box {
  margin-bottom: 32rpx;
}

.question-content {
  font-size: 36rpx;
  color: rgba(0, 0, 0, 0.9);
  line-height: 1.6;
}

.question-content p {
  margin: 0;
  line-height: 1.6;
}

/* Options List */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.option-item {
  position: relative;
  padding: 32rpx 48rpx;
  border-radius: 48rpx;
  border: 4rpx solid rgba(0, 0, 0, 0.03);
  background-color: #fff;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.option-item.selected {
  background-color: rgba(99, 102, 241, 0.1);
}

.option-item.correct {
  background-color: rgba(16, 185, 129, 0.1);
  border-color: #10B981;
}

.option-item.wrong {
  background-color: rgba(244, 63, 94, 0.1);
  border-color: #F43F5E;
}

.option-label-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.05);
}

.option-label-box.correct-label {
  background-color: #10B981;
}

.option-label-box.wrong-label {
  background-color: #F43F5E;
}

.option-label {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.3);
}

.option-label-box.correct-label .option-label,
.option-label-box.wrong-label .option-label {
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.3);
  line-height: 1.5;
}

.option-text.active-text {
  color: rgba(0, 0, 0, 0.8);
}

.option-status {
  margin-left: auto;
  font-size: 40rpx;
  color: #10B981;
}

.option-status.wrong-status {
  color: #F43F5E;
}

/* Answer Info Section */
.answer-info-section {
  margin-top: 32rpx;
}

.answer-info-card {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.answer-row {
  gap: 24rpx;
}

.answer-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.answer-box.correct-box {
  background-color: #10B981;
  box-shadow: 0 8rpx 16rpx rgba(16, 185, 129, 0.2);
}

.answer-box.wrong-box {
  background-color: #F43F5E;
  box-shadow: 0 8rpx 16rpx rgba(244, 63, 94, 0.2);
}

.answer-letter {
  font-size: 36rpx;
  color: #fff;
}

.answer-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.answer-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

.answer-sub {
  color: rgba(0, 0, 0, 0.5);
}

.correct-text {
  color: #10B981;
}

.wrong-text {
  color: #F43F5E;
}

/* Analysis Section */
.analysis-section {
  margin-top: 48rpx;
}

.analysis-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.analysis-icon {
  font-size: 32rpx;
  color: #F59E0B;
}

.analysis-title {
  color: rgba(0, 0, 0, 0.6);
  letter-spacing: 4rpx;
}

.analysis-card {
  background-color: #fff;
  border-radius: 64rpx;
  padding: 48rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.correct-answer-row {
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.correct-answer-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 32rpx;
  background-color: #10B981;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(16, 185, 129, 0.2);
}

.correct-letter {
  font-size: 36rpx;
  color: #fff;
}

.correct-info {
  display: flex;
  flex-direction: column;
}

.correct-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.9);
}

/* Logic Box */
.logic-box {
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 48rpx;
  padding: 32rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.logic-label {
  color: rgba(0, 0, 0, 0.3);
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  display: block;
}

.logic-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.7);
  line-height: 1.6;
}

.logic-text p {
  margin: 0;
  line-height: 1.6;
}

/* Key Point Box */
.key-point-box {
  background-color: rgba(251, 191, 36, 0.1);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.2);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.key-icon-box {
  width: 64rpx;
  height: 64rpx;
  background-color: #fff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(251, 191, 36, 0.2);
}

.key-icon {
  font-size: 32rpx;
  color: #F59E0B;
}

.key-content {
  flex: 1;
}

.key-label {
  color: rgba(180, 83, 9, 1);
  margin-bottom: 4rpx;
  display: block;
}

.key-text {
  color: rgba(180, 83, 9, 0.7);
}

/* Back Section */
.back-section {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  padding-bottom: 48rpx;
}

.back-btn {
  padding: 24rpx 64rpx;
  background-color: #07C160;
  color: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(7, 193, 96, 0.2);
}

.back-text {
  font-size: 28rpx;
}

/* Utility Classes */
.flex-row {
  display: flex;
  align-items: center;
}

.text-bold {
  font-weight: 900;
}

.text-small {
  font-size: 24rpx;
}

.text-xs {
  font-size: 20rpx;
}