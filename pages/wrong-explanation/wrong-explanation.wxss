/* pages/wrong-explanation/wrong-explanation.wxss - 错题解析页面样式 */

.explanation-page {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

/* Card */
.card {
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

/* Question Card */
.question-card {
  padding: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.topic-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #DBEAFE;
}

.topic-badge .topic-text {
  color: #2563EB;
}

.date-text {
  color: rgba(0, 0, 0, 0.4);
}

.difficulty-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background-color: #FEF3C7;
  color: #D97706;
}

.remove-btn {
  padding: 8rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}

.question-content-box {
  margin-bottom: 24rpx;
}

.question-content {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.6;
}

/* Options List */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 20rpx;
  border-radius: 20rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border: 2rpx solid transparent;
}

.option-item.correct {
  background-color: #D1FAE5;
  border-color: #10B981;
}

.option-item.wrong {
  background-color: #FEE2E2;
  border-color: #EF4444;
}

.option-left {
  flex-shrink: 0;
}

.option-key-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  background-color: rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-key-box.correct-bg {
  background-color: #10B981;
}

.option-key-box.wrong-bg {
  background-color: #EF4444;
}

.option-key {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.7);
}

.option-key-box.correct-bg .option-key,
.option-key-box.wrong-bg .option-key {
  color: #fff;
}

.option-right {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.5;
}

.option-tag {
  font-size: 22rpx;
  color: #10B981;
}

.option-tag.wrong-tag {
  color: #EF4444;
}

/* Result Card */
.result-card {
  padding: 24rpx;
}

.result-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.result-header.success {
  background-color: #D1FAE5;
}

.result-header.error {
  background-color: #FEE2E2;
}

.result-icon {
  font-size: 24rpx;
}

.result-header.success .result-text {
  color: #10B981;
}

.result-header.error .result-text {
  color: #EF4444;
}

.answer-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.answer-row {
  display: flex;
  align-items: center;
}

.answer-label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.5);
}

.answer-value {
  font-size: 28rpx;
}

.answer-value.correct {
  color: #10B981;
}

.answer-value.wrong {
  color: #EF4444;
}

/* Explanation Card */
.explanation-card {
  padding: 24rpx;
}

.explanation-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.explanation-icon {
  font-size: 28rpx;
}

.explanation-title {
  font-size: 30rpx;
  color: rgba(0, 0, 0, 0.85);
}

.explanation-content {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.7);
  line-height: 1.6;
}

/* Action Bar */
.action-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
}

.retry-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 24rpx;
  background-color: #07C160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.2);
}

.retry-text {
  font-size: 28rpx;
  color: #fff;
}

/* Utility */
.text-bold {
  font-weight: 700;
}

.text-small {
  font-size: 24rpx;
}

.text-muted {
  color: rgba(0, 0, 0, 0.4);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}