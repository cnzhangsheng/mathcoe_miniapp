<!--pages/all-wrong/all-wrong.wxml - 全部错题页面 -->
<view class="all-wrong-page">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">全部错题</text>
    <text class="page-count">共 {{wrongQuestions.length}} 题</text>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item {{filterType === 'all' ? 'active' : ''}}" bindtap="setFilter" data-type="all">
      <text>全部</text>
    </view>
    <view class="filter-item {{filterType === 'recent' ? 'active' : ''}}" bindtap="setFilter" data-type="recent">
      <text>最近一周</text>
    </view>
  </view>

  <!-- 错题列表 -->
  <block wx:if="{{filteredQuestions.length > 0}}">
    <view class="question-list">
      <block wx:for="{{filteredQuestions}}" wx:key="id">
        <view class="question-item card" bindtap="viewQuestion" data-question="{{item}}">
          <view class="question-top flex-between">
            <view class="question-meta flex-row">
              <view class="topic-badge">
                <text class="topic-text text-small">{{item.topicTitle}}</text>
              </view>
            </view>
            <text class="date-text text-small">{{item.dateLabel}}</text>
          </view>

          <view class="question-content">
            <rich-text nodes="{{item.content}}"></rich-text>
          </view>

          <view class="question-bottom flex-between">
            <text class="retry-text text-small">重练 {{item.retry_count}} 次</text>
            <view class="mini-btn primary-bg" catchtap="retryQuestion" data-id="{{item.question_id}}">
              <text class="mini-text text-small">重练</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:if="{{filteredQuestions.length === 0}}">
    <view class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-title">暂无错题</text>
    </view>
  </block>
</view>