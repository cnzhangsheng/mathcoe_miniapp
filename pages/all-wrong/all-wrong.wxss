/* pages/all-wrong/all-wrong.wxss */

.all-wrong-page {
  padding: 20rpx;
  padding-bottom: 100rpx;
  background-color: #F8F8F8;
  min-height: 100vh;
}

.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(0, 0, 0, 0.85);
}

.page-count {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
}

.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  background-color: #fff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.5);
}

.filter-item.active {
  background-color: #07C160;
  color: #fff;
}

.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.question-item {
  padding: 24rpx;
  border-radius: 24rpx;
}

.question-top {
  margin-bottom: 16rpx;
}

.question-meta {
  gap: 12rpx;
}

.topic-badge {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background-color: #DBEAFE;
}

.topic-badge .topic-text {
  color: #2563EB;
}

.date-text {
  color: rgba(0, 0, 0, 0.4);
}

.date-text {
  color: rgba(0, 0, 0, 0.4);
}

.question-content {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.85);
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.question-content p {
  margin: 0;
  padding: 0;
}

.question-bottom {
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.03);
}

.retry-text {
  color: rgba(0, 0, 0, 0.4);
}

.mini-btn {
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.mini-text {
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.3);
}

.card {
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-small {
  font-size: 24rpx;
}

.primary-bg {
  background-color: #07C160;
}