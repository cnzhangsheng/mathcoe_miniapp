<!-- pages/discover/discover.wxml -->
<view class="discover-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading && question}}">
    <!-- 题目卡片 -->
    <view class="question-card">
      <!-- 题目内容 -->
      <view class="question-content-box">
        <rich-text class="question-content" nodes="{{question.content}}"></rich-text>
      </view>

      <!-- 选项列表 -->
      <view class="options-list" wx:if="{{question.options && question.options.length > 0}}">
        <block wx:for="{{question.options}}" wx:key="label">
          <view class="option-item">
            <view class="option-label-box">
              <text class="option-label">{{item.label}}</text>
            </view>
            <rich-text class="option-text" nodes="{{item.text}}"></rich-text>
          </view>
        </block>
      </view>

      <!-- 点赞和收藏按钮 -->
      <view class="action-buttons">
        <view class="action-btn {{isLiked ? 'active' : ''}}" bindtap="toggleLike">
          <text class="action-icon">{{isLiked ? '👍' : '👍🏻'}}</text>
          <text class="action-text">{{isLiked ? '已点赞' : '点赞'}}</text>
        </view>
        <view class="action-btn {{isFavorited ? 'active' : ''}}" bindtap="toggleFavorite">
          <text class="action-icon">{{isFavorited ? '❤️' : '🤍'}}</text>
          <text class="action-text">{{isFavorited ? '已收藏' : '收藏'}}</text>
        </view>
      </view>

      <!-- 查看答案按钮 -->
      <view class="answer-btn" bindtap="toggleAnswer">
        <text class="answer-btn-text">{{showAnswer ? '隐藏答案' : '查看答案'}}</text>
      </view>

      <!-- 答案和解析 -->
      <view class="answer-section" wx:if="{{showAnswer}}">
        <view class="answer-box">
          <view class="answer-marker"></view>
          <view class="answer-content">
            <text class="answer-label">正确答案</text>
            <text class="answer-value">{{question.answer}}</text>
          </view>
        </view>

        <view class="explanation-box">
          <view class="explanation-marker"></view>
          <view class="explanation-content">
            <text class="explanation-label">题目解析</text>
            <rich-text class="explanation-text" nodes="{{question.explanation}}"></rich-text>
          </view>
        </view>
      </view>
    </view>

    <!-- 下一题按钮 -->
    <view class="next-btn" bindtap="nextQuestion">
      <text class="next-btn-text">下一题</text>
    </view>
  </block>

  <!-- 无题目状态 -->
  <view wx:if="{{!loading && !question}}" class="empty-state">
    <text class="empty-text">暂无题目，请稍后再试</text>
    <view class="retry-btn" bindtap="loadRandomQuestion">
      <text class="retry-text">重新加载</text>
    </view>
  </view>
</view>