<!--pages/login/login.wxml - 授权登录页面-->
<view class="login-container">
  <!-- 背景装饰 -->
  <view class="bg-decorator"></view>
  <view class="bg-decorator-2"></view>

  <!-- Logo 区域 -->
  <view class="logo-section">
    <view class="logo-box">
      <image class="logo-icon" src="/assets/logo.png" mode="aspectFit"></image>
    </view>
    <text class="app-name text-bold">袋鼠数学助理</text>
    <text class="app-slogan text-small">Kangaroo Math Assistant</text>
    <text class="app-desc">您的 AI 数字化思维成长伙伴</text>
  </view>

  <!-- 特性展示 -->
  <view class="features-section">
    <view class="feature-card">
      <view class="feature-icon-box primary-bg">
        <text>🎯</text>
      </view>
      <text class="feature-title text-small text-bold">AI深度测评</text>
      <text class="feature-desc text-xs">雷达图分析思维模型</text>
    </view>
    <view class="feature-card">
      <view class="feature-icon-box blue-bg">
        <text>📊</text>
      </view>
      <text class="feature-title text-small text-bold">全级真题实练</text>
      <text class="feature-desc text-xs">历年L1至L6真题库</text>
    </view>
    <view class="feature-card">
      <view class="feature-icon-box amber-bg">
        <text>🏆</text>
      </view>
      <text class="feature-title text-small text-bold">成长轨迹追踪</text>
      <text class="feature-desc text-xs">数字化记录进步点滴</text>
    </view>
  </view>

  <!-- 登录区域 -->
  <view class="login-section">
    <!-- 年级选择 -->
    <view class="grade-section">
      <text class="grade-label text-small text-bold">选择年级</text>
      <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
        <view class="grade-picker">
          <text class="grade-value">{{grades[gradeIndex]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 难度等级选择 -->
    <view class="grade-section">
      <text class="grade-label text-small text-bold">难度等级</text>
      <picker mode="selector" range="{{difficultyLevels}}" value="{{difficultyIndex}}" bindchange="onDifficultyChange">
        <view class="grade-picker">
          <text class="grade-value">{{difficultyLevels[difficultyIndex]}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 微信授权按钮 -->
    <button
      class="login-btn {{loading ? 'loading' : ''}}"
      open-type="getUserInfo"
      bindgetuserinfo="handleLogin"
      disabled="{{loading}}"
    >
      <view class="btn-content flex-row">
        <text class="btn-icon" wx:if="{{!loading}}">📱</text>
        <text class="btn-text text-bold">{{loading ? '登录中...' : '微信授权登录'}}</text>
      </view>
    </button>

    <!-- 提示 -->
    <view class="tips-section">
      <text class="tip-text text-xs">首次登录将自动创建账号</text>
    </view>
  </view>

  <!-- 隐私协议 -->
  <view class="privacy-section flex-row">
    <text class="privacy-text text-xs">登录即表示同意</text>
    <text class="privacy-link text-xs text-bold">《用户协议》</text>
    <text class="privacy-text text-xs">和</text>
    <text class="privacy-link text-xs text-bold">《隐私政策》</text>
  </view>
</view>