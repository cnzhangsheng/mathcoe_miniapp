/* app.wxss - Global styles */
page {
  background-color: #F8F8F8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #333;
}

.container {
  padding: 20rpx;
}

/* Primary color: WeChat green */
.primary-color {
  color: #07C160;
}

.primary-bg {
  background-color: #07C160;
}

/* Card styles */
.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

/* Button styles */
.btn-primary {
  background-color: #07C160;
  color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-weight: bold;
  text-align: center;
}

.btn-secondary {
  background-color: #F0F0F0;
  color: #666;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-weight: bold;
  text-align: center;
}

/* Progress bar */
.progress-bar {
  height: 8rpx;
  background-color: #E0E0E0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background-color: #07C160;
  border-radius: 4rpx;
}

/* Flex utilities */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Text utilities */
.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

.text-small {
  font-size: 12px;
}

.text-muted {
  color: #999;
}